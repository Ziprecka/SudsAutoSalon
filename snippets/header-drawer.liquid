{% comment %}
  Suds mobile drawer navigation. Mirrors the simplified local-service site map.
{% endcomment %}

{%- assign suds_nav = 'Home|/|Services|/pages/services|Packages|/#packages|Gallery|/#gallery|Reviews|/pages/reviews|Service Areas|/pages/service-areas|Contact|/pages/contact-us|Book Now|/collections/mobile-details' | split: '|' -%}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {% render 'icon-hamburger' %}
        {% render 'icon-close' %}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              {%- for item in suds_nav -%}
                {%- assign mod = forloop.index0 | modulo: 2 -%}
                {%- if mod == 0 -%}
                  {%- assign label = item -%}
                  {%- assign url = suds_nav[forloop.index] -%}
                  <li>
                    <a
                      id="HeaderDrawer-suds-{{ label | handleize }}"
                      href="{{ url }}"
                      class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if label == 'Book Now' %} menu-drawer__menu-item--suds-book{% endif %}{% if request.path == url %} menu-drawer__menu-item--active{% endif %}"
                      {% if request.path == url %}
                        aria-current="page"
                      {% endif %}
                    >
                      {{ label }}
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </nav>
          <div class="menu-drawer__utility-links">
            <a href="/collections/mobile-details" class="menu-drawer__account link focus-inset h5 medium-hide large-up-hide">
              Book Your Mobile Detail
            </a>
            <ul class="list list-social list-unstyled" role="list">
              {%- if settings.social_instagram_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_instagram_link }}" class="list-social__link link">
                    {%- render 'icon-instagram' -%}
                    <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </details>
</header-drawer>
