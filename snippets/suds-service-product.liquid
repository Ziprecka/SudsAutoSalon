{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign package_key = product.handle
  assign service_tier = 'custom'

  case product.handle
    when 'basic-detail', 'mini-detail'
      assign service_tier = 'basic'
    when 'signature-detail', 'interior-detail'
      assign service_tier = 'signature'
    when 'elite-detail', 'full-detail'
      assign service_tier = 'elite'
  endcase

  assign lower_product_title = product.title | downcase
  if service_tier == 'custom'
    if lower_product_title contains 'basic detail'
      assign service_tier = 'basic'
    elsif lower_product_title contains 'mini detail'
      assign service_tier = 'basic'
    elsif lower_product_title contains 'signature detail'
      assign service_tier = 'signature'
    elsif lower_product_title contains 'interior detail'
      assign service_tier = 'signature'
    elsif lower_product_title contains 'elite detail'
      assign service_tier = 'elite'
    elsif lower_product_title contains 'full detail'
      assign service_tier = 'elite'
    endif
  endif

  assign headline = product.title | append: ' Mobile Detailing'
  assign subheadline = 'A premium inside-and-out mobile detail from Suds Auto Salon, matched to your vehicle condition and booked as an appointment-based service.'
  assign position = 'A full inside-and-out mobile detail for Seattle-area drivers.'
  assign best_for = 'Daily drivers, commuters, families, and vehicles that need a cleaner baseline.'
  assign not_for = 'Severe condition, heavy pet hair, odor, stains, mold concerns, or restoration-level work without a quote first.'
  assign included_one = 'Interior cleaning for seats, carpets, mats, touchpoints, glass, and daily-driver buildup.'
  assign included_two = 'Exterior hand wash, wheels, tires, glass, trim attention, and finish-focused cleanup.'
  assign included_three = 'Package guidance from Sam so the service fits the vehicle instead of forcing a generic menu.'
  assign wash_reason = 'A car wash cleans the surface. A real detail addresses the buildup that collects from actually driving the vehicle: interior grime, dust, crumbs, body oils, road film, dirty wheels, contaminated paint, and tired finishes. You are paying for time, process, and a visible reset - not a rushed rinse.'
  assign heavy_note = 'If the vehicle has heavy pet hair, stains, odor, or neglected areas, send photos first so Sam can confirm the right level.'
  assign faq_time = 'Timing depends on vehicle size, condition, access, and add-ons. Sam will confirm the expected appointment window before the detail.'
  assign package_question = 'If you are unsure, send photos first. Sam can point you toward the lightest package that can still do the job properly.'

  case service_tier
    when 'basic'
      assign headline = 'Seattle Mobile Detailing for a Cleaner, Fresher Daily Driver'
      assign subheadline = 'The Basic Detail is built for vehicles that are already fairly maintained but need a professional interior and exterior refresh without the depth of a heavier reset.'
      assign position = 'Best for maintained vehicles that need a lighter reset.'
      assign best_for = 'Maintained vehicles, recent detail customers, light dust, mild road film, cleaner daily drivers, and monthly or bi-monthly upkeep.'
      assign not_for = 'Heavy pet hair, stains, odor, neglected interiors, rough paint, or vehicles that have not been cleaned in months.'
      assign included_one = 'Light interior cleanup for surfaces, touchpoints, glass, mats, and normal dust.'
      assign included_two = 'Exterior wash, wheels, tires, glass, and clean finish presentation.'
      assign included_three = 'A professional upkeep detail that keeps the vehicle fresh without charging you for deeper reset work you do not need.'
      assign heavy_note = 'If photos show heavier buildup, Sam may recommend Signature or Elite so the appointment has enough time.'
      assign faq_time = 'Basic is usually the shortest Suds detail because it is built for maintained vehicles. Vehicle size, access, and condition still affect the final appointment window.'
      assign package_question = 'Choose Basic when the vehicle is already in decent condition and needs upkeep, not rescue-level cleaning.'
    when 'signature'
      assign headline = 'Seattle Mobile Detailing for the Everyday Full Reset'
      assign subheadline = 'The Signature Detail is the recommended full-service package for most drivers who want their vehicle cleaned properly inside and out at home or work.'
      assign position = 'Best for most daily drivers that need a proper interior and exterior reset.'
      assign best_for = 'Commuter vehicles, family cars, normal buildup, light pet use, weather grime, and first-time Suds customers.'
      assign not_for = 'Severe pet hair, strong odor, heavy staining, mold concerns, or vehicles needing the highest level of reset.'
      assign included_one = 'Interior reset for daily-driver buildup, seats, mats, carpets, glass, touchpoints, and common mess.'
      assign included_two = 'Exterior hand wash, wheels, tires, trim attention, glass, and finish cleanup.'
      assign included_three = 'The strongest all-around first booking before maintenance or exterior protection.'
      assign heavy_note = 'If the vehicle has embedded pet hair, odor, or neglected areas, Elite Reset may be the better fit.'
      assign faq_time = 'Signature takes longer than Basic because it is built for a more complete inside-and-out reset. Vehicle size, condition, and add-ons determine the final timing.'
      assign package_question = 'Choose Signature if this is your first Suds booking or your daily driver needs a real interior and exterior refresh.'
    when 'elite'
      assign headline = 'Seattle Mobile Detailing for Cars That Need a Real Reset'
      assign subheadline = 'The Elite Detail is a premium interior and exterior mobile detail for Seattle drivers who want their vehicle cleaned properly - not rushed through a basic wash.'
      assign position = 'Best for vehicles with heavier buildup, rougher exterior feel, or owners who want the strongest non-coating detail.'
      assign best_for = 'Family SUVs, pet vehicles, heavier daily-driver buildup, resale prep, rougher exterior feel, and customers who want the most complete non-coating detail.'
      assign not_for = 'Scratch removal guarantees, severe odor guarantees, mold remediation without inspection, or ceramic-level long-term paint protection.'
      assign included_one = 'Deep interior cleaning for daily-driver buildup, dirty touchpoints, mats, carpets, seats, and the areas that collect grime.'
      assign included_two = 'Careful exterior wash, clay bar decontamination, wheel cleanup, trim attention, glass, and hand wax.'
      assign included_three = 'Private mobile service at your home or office with more time reserved for a stronger visible reset.'
      assign wash_reason = 'A car wash cleans the surface. Elite is built for more time, more depth, clay bar decontamination, interior buildup, rougher exterior feel, and a stronger non-coating reset. It can improve the vehicle significantly without pretending every stain, odor, or scratch can be fully removed.'
      assign heavy_note = 'Pet hair, stains, odor, and heavier condition can change the time required. Photos help Sam confirm the right path before booking.'
      assign faq_time = 'Elite requires the largest appointment window because it is built for heavier condition and more exterior refinement. Vehicle size, pet hair, stains, odor, and access can change timing.'
      assign package_question = 'Choose Elite if the vehicle feels overdue, has heavier buildup, needs resale-level attention, or you want the strongest detail before considering protection.'
  endcase

  assign featured_image = product.featured_image
  assign clean_description_text = product.description | strip_html | strip
  assign show_product_description = true
  if clean_description_text == blank
    assign show_product_description = false
  elsif clean_description_text contains 'WHO THIS IS FOR'
    assign show_product_description = false
  elsif clean_description_text contains 'Who This Is For'
    assign show_product_description = false
  endif

  assign variant_picker_block = blank
  assign buy_buttons_block = blank
  assign has_app_block = false
  for block in section.blocks
    if block.type == 'variant_picker'
      assign variant_picker_block = block
    elsif block.type == 'buy_buttons'
      assign buy_buttons_block = block
    elsif block.type == '@app'
      assign has_app_block = true
    endif
  endfor

  assign basic_product = all_products['basic-detail']
  if basic_product == blank
    assign basic_product = all_products['mini-detail']
  endif
  assign basic_url = '/products/basic-detail'
  if basic_product != blank
    assign basic_url = basic_product.url
  endif

  assign signature_product = all_products['signature-detail']
  if signature_product == blank
    assign signature_product = all_products['interior-detail']
  endif
  assign signature_url = '/products/signature-detail'
  if signature_product != blank
    assign signature_url = signature_product.url
  endif

  assign elite_product = all_products['elite-detail']
  if elite_product == blank
    assign elite_product = all_products['full-detail']
  endif
  assign elite_url = '/products/elite-detail'
  if elite_product != blank
    assign elite_url = elite_product.url
  endif
-%}

{{ 'section-suds-service-product.css' | asset_url | stylesheet_tag }}

<div class="suds-service-product" data-suds-service-product="{{ package_key }}" data-suds-service-tier="{{ service_tier }}">
  <section class="suds-service-hero" id="overview">
    <div class="suds-service-hero__wrap">
      <div class="suds-service-hero__copy">
        <p class="suds-service-hero__eyebrow">Seattle Mobile Detailing</p>
        <h1>{{ headline }}</h1>
        <p class="suds-service-hero__lead">{{ subheadline }}</p>

        <div class="suds-service-proofline">
          <a href="#reviews">Review-backed local service</a>
          <span>Mobile service at your home or office</span>
        </div>

        <div class="suds-service-hero__badges" aria-label="Suds Auto Salon trust signals">
          <span>Private mobile detailer</span>
          <span>Seattle-area service</span>
          <span>Interior + exterior detailing</span>
          <span>Appointment-based service</span>
          <span>Trusted by local drivers</span>
        </div>

        <div class="suds-service-booking" id="suds-service-booking-{{ section.id }}">
          <div class="suds-service-booking__price">
            <p>Service price</p>
            {% render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' %}
          </div>
          <p class="suds-service-booking__fit">{{ position }}</p>
          <product-info
            id="ProductInfo-{{ section.id }}"
            data-section="{{ section.id }}"
            data-url="{{ product.url }}"
            class="suds-service-booking__product-info"
          >
            {%- if variant_picker_block != blank -%}
              {% render 'product-variant-picker', product: product, block: variant_picker_block, product_form_id: product_form_id %}
            {%- endif -%}
            {%- if buy_buttons_block != blank -%}
              {% render 'buy-buttons',
                block: buy_buttons_block,
                product: product,
                product_form_id: product_form_id,
                section_id: section.id,
                show_pickup_availability: false,
                force_hide_dynamic_checkout: true,
                button_label: 'Schedule This Detail'
              %}
            {%- endif -%}
          </product-info>
          <div class="suds-service-booking__actions">
            <a href="#compare">Compare Packages</a>
            <a href="/pages/contact-us">Ask About This Package</a>
          </div>
          <p class="suds-service-booking__meta">Seattle + surrounding areas. Appointment-based mobile service.</p>
        </div>
      </div>

      <div class="suds-service-hero-media" aria-label="{{ product.title | escape }} photo gallery">
        <div class="suds-service-hero-media__featured">
          {%- if featured_image != blank -%}
            {%- assign featured_alt = featured_image.alt | default: product.title | escape -%}
            {{
              featured_image
              | image_url: width: 1400
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                widths: '540, 720, 960, 1200, 1400',
                sizes: '(min-width: 990px) 44vw, 100vw',
                alt: featured_alt
            }}
          {%- else -%}
            <div class="suds-service-hero-media__empty">Suds Auto Salon mobile detailing</div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="suds-service-hero-media__thumbs">
            {%- for image in product.images limit: 4 -%}
              {%- assign thumb_alt = image.alt | default: product.title | escape -%}
              <div class="suds-service-hero-media__thumb">
                {{
                  image
                  | image_url: width: 360
                  | image_tag:
                    loading: 'lazy',
                    widths: '160, 240, 360',
                    sizes: '(min-width: 990px) 10vw, 23vw',
                    alt: thumb_alt
                }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <div class="suds-service-hero-media__note">Real vehicle photos help set the right expectation before booking.</div>
      </div>
    </div>
  </section>

  <nav class="suds-service-nav" aria-label="{{ product.title | escape }} page navigation">
    <a href="#overview">Overview</a>
    <a href="#best-for">Best For</a>
    <a href="#included">Included</a>
    <a href="#reviews">Reviews</a>
    <a href="#faq">FAQ</a>
    <a href="#suds-service-booking-{{ section.id }}">Book</a>
  </nav>

  <section class="suds-service-section" id="best-for">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Best fit</p>
        <h2>Know exactly what this detail is built for</h2>
        <p>{{ best_for }}</p>
      </div>
      <div class="suds-service-card-grid">
        <article>
          <h3>Best fit</h3>
          <p>{{ position }}</p>
        </article>
        <article>
          <h3>Not the right fit</h3>
          <p>{{ not_for }}</p>
        </article>
        <article>
          <h3>Photo check</h3>
          <p>{{ heavy_note }}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="included">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Included</p>
        <h2>Interior and exterior detailing in one appointment</h2>
        <p>Every main Suds package is an inside-and-out mobile detail. The tier changes the depth, time, and condition it is built to handle.</p>
      </div>
      <div class="suds-service-checks">
        <div>{{ included_one }}</div>
        <div>{{ included_two }}</div>
        <div>{{ included_three }}</div>
        <div>Service recommendations matched to vehicle size, condition, route area, and goals.</div>
      </div>
      <div class="suds-service-inline-cta">
        <a href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
        <a href="/pages/contact-us">Request a Quote</a>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="value">
    <div class="suds-service-section__wrap suds-service-value">
      <div>
        <p class="suds-service-kicker">Why it costs more</p>
        <h2>Why this costs more than a car wash</h2>
      </div>
      <p>{{ wash_reason }}</p>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="results">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Real results</p>
        <h2>Photo proof without the messy image stack</h2>
        <p>Photos should build trust, not bury the booking button. This gallery keeps the strongest vehicle images organized and easy to scan.</p>
      </div>
      <div class="suds-service-results-grid">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images limit: 6 -%}
            {%- assign result_alt = image.alt | default: product.title | escape -%}
            <figure>
              {{
                image
                | image_url: width: 720
                | image_tag:
                  loading: 'lazy',
                  widths: '280, 420, 560, 720',
                  sizes: '(min-width: 990px) 31vw, 100vw',
                  alt: result_alt
              }}
            </figure>
          {%- endfor -%}
        {%- else -%}
          <div class="suds-service-results-grid__empty">Add before/after photos to this product in Shopify to fill this proof gallery.</div>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="trust">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Why Suds Auto Salon</p>
        <h2>Private mobile detailing, not assembly-line cleaning</h2>
        <p>Suds is built around direct communication, mobile convenience, and a detailer-led process. The goal is a visible reset matched to the actual condition of your vehicle.</p>
      </div>
      <div class="suds-service-trust-grid">
        <article><h3>Private service</h3><p>Appointment-based detailing handled directly by Sam, not a high-volume wash line.</p></article>
        <article><h3>Mobile convenience</h3><p>Your vehicle is detailed at your home, office, or approved service location when access and routing work.</p></article>
        <article><h3>Condition matched</h3><p>Basic, Signature, and Elite are matched to condition so you do not underbook or overpay for the wrong level.</p></article>
        <article><h3>Local focus</h3><p>Built for Seattle-area drivers dealing with rain, road film, commuting, pets, and outdoor parking.</p></article>
      </div>
    </div>
  </section>

  {%- if show_product_description -%}
    <section class="suds-service-section suds-service-description">
      <div class="suds-service-section__wrap">
        <div class="suds-service-section__head">
          <p class="suds-service-kicker">Service details</p>
          <h2>More detail about this package</h2>
        </div>
        <div class="suds-service-description__body rte">
          {{ product.description }}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="suds-service-section suds-service-section--dark" id="process">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">How booking works</p>
        <h2>Simple appointment flow. Clear recommendation.</h2>
      </div>
      <div class="suds-service-steps">
        <article><strong>01</strong><h3>Choose your detail</h3><p>Pick the package that matches your vehicle's condition or request a quote if you are unsure.</p></article>
        <article><strong>02</strong><h3>Schedule your appointment</h3><p>Book a mobile detailing appointment online and share access details for your location.</p></article>
        <article><strong>03</strong><h3>Suds comes to you</h3><p>The service is performed at your home, office, or approved location in the Seattle area.</p></article>
        <article><strong>04</strong><h3>Enjoy the reset</h3><p>Cleaner cabin, sharper exterior, and a vehicle that feels easier to be proud of.</p></article>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="compare">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Compare packages</p>
        <h2>Basic, Signature, and Elite are one connected service ladder</h2>
        <p>All three are inside-and-out mobile details. Choose by vehicle condition and how much reset is needed.</p>
      </div>
      <div class="suds-service-package-grid">
        <article class="{% if service_tier == 'basic' %}is-active{% endif %}">
          <span>Basic Detail</span>
          <h3>Lighter upkeep reset</h3>
          <p>Best for maintained vehicles that need a cleaner, fresher feel.</p>
          <a href="{{ basic_url }}">{% if service_tier == 'basic' %}Book Basic{% else %}View Basic Detail{% endif %}</a>
        </article>
        <article class="{% if service_tier == 'signature' %}is-active{% endif %}">
          <span>Signature Detail</span>
          <h3>Best all-around detail</h3>
          <p>Best for most daily drivers needing a proper interior and exterior reset.</p>
          <a href="{{ signature_url }}">{% if service_tier == 'signature' %}Book Signature{% else %}View Signature Detail{% endif %}</a>
        </article>
        <article class="{% if service_tier == 'elite' %}is-active{% endif %}">
          <span>Elite Detail</span>
          <h3>Premium deep reset</h3>
          <p>Best for heavier buildup, rougher paint feel, and stronger transformation.</p>
          <a href="{{ elite_url }}">{% if service_tier == 'elite' %}Book Elite{% else %}View Elite Detail{% endif %}</a>
        </article>
      </div>
      <div class="suds-service-inline-cta">
        <a href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
        <a href="/pages/contact-us">Ask Which Package Fits</a>
      </div>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="reviews">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Reviews</p>
        <h2>Trusted by Seattle-area drivers</h2>
        <p>Customer reviews load below. Suds Auto Salon is trusted by local drivers for private mobile detailing, protection work, and ongoing maintenance.</p>
      </div>
      {%- if has_app_block -%}
        <div class="suds-service-reviews-app">
          {%- for block in section.blocks -%}
            {%- if block.type == '@app' -%}
              {% render block %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="suds-service-reviews-app">
          <p>Review integration is ready for the product template. Add or reconnect the review app block in Shopify to display live product reviews here.</p>
        </div>
      {%- endif -%}
    </div>
  </section>

  <section class="suds-service-section" id="faq">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">FAQ</p>
        <h2>Questions before you book</h2>
      </div>
      <div class="suds-service-faq">
        <details><summary>How long does this detail take?</summary><p>{{ faq_time }}</p></details>
        <details><summary>Do you come to my location?</summary><p>Yes. Suds Auto Salon is mobile and serves Seattle and nearby areas at homes, offices, and approved locations when route timing and access work.</p></details>
        <details><summary>Is this a maintenance wash?</summary><p>No. This is a mobile detail package. Maintenance plans are best after a vehicle has already been reset and you want to keep it consistently clean.</p></details>
        <details><summary>Does this remove scratches?</summary><p>Cleaning, clay, and wax can improve gloss and how the exterior feels, but scratch removal requires paint correction. Paint enhancement or correction may be recommended separately for finish defects.</p></details>
        <details><summary>What if my vehicle has pet hair, stains, or heavy buildup?</summary><p>Send photos before booking. Heavy pet hair, severe staining, odor, mold concerns, or unusual buildup may require more time, an add-on, or a higher package level.</p></details>
        <details><summary>What should I remove before the appointment?</summary><p>Remove personal items, valuables, child seats if possible, and anything you do not want moved. This keeps the appointment focused on cleaning instead of sorting belongings.</p></details>
        <details><summary>Do I need water or power available?</summary><p>Access needs can vary by location and service setup. Share your parking and access details when booking so Sam can confirm what is needed for the appointment.</p></details>
        <details><summary>What package should I choose?</summary><p>{{ package_question }}</p></details>
        <details><summary>Can I add ceramic coating or paint correction?</summary><p>Yes. Ceramic coating and paint correction are separate upgrades. They are best quoted after Sam understands the paint condition, vehicle size, and your protection goals.</p></details>
      </div>
    </div>
  </section>

  <section class="suds-service-final" id="book">
    <div class="suds-service-final__wrap">
      <h2>If your vehicle feels overdue, this is the easiest way to reset it without leaving home.</h2>
      <p>Schedule this mobile detail or send photos first if you want Sam to confirm the right package before you book.</p>
      <div class="suds-service-final__actions">
        <a href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
        <a href="/pages/contact-us">Request a Quote</a>
        <a href="sms:+14253618838">Text Photos for a Faster Quote</a>
      </div>
    </div>
  </section>

  <a class="suds-service-sticky" href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
</div>

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
-%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {% if seo_media -%}
      "image": [
        {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
      ],
    {%- endif %}
    "description": {{ product.description | strip_html | default: subheadline | json }},
    {% if product.selected_or_first_available_variant.sku != blank -%}
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "offers": [
      {%- for variant in product.variants -%}
        {
          "@type" : "Offer",
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
          "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
          "price" : {{ variant.price | divided_by: 100.00 | json }},
          "priceCurrency" : {{ cart.currency.iso_code | json }},
          "url" : {{ request.origin | append: variant.url | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does this mobile detail take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_time | json }}
      }
    },
