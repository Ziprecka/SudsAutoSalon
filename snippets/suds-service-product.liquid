{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign package_key = product.handle
  assign service_tier = 'custom'

  case product.handle
    when 'basic-detail', 'mini-detail'
      assign service_tier = 'basic'
    when 'signature-detail', 'interior-detail'
      assign service_tier = 'signature'
    when 'elite-detail', 'full-detail'
      assign service_tier = 'elite'
  endcase

  assign lower_product_title = product.title | downcase
  if service_tier == 'custom'
    if lower_product_title contains 'basic detail'
      assign service_tier = 'basic'
    elsif lower_product_title contains 'mini detail'
      assign service_tier = 'basic'
    elsif lower_product_title contains 'signature detail'
      assign service_tier = 'signature'
    elsif lower_product_title contains 'interior detail'
      assign service_tier = 'signature'
    elsif lower_product_title contains 'elite detail'
      assign service_tier = 'elite'
    elsif lower_product_title contains 'full detail'
      assign service_tier = 'elite'
    endif
  endif

  assign headline = product.title | append: ' Mobile Detail'
  assign subheadline = 'Private mobile detailing at your home or office, matched to the condition of the vehicle before you book.'
  assign position = 'Inside-and-out mobile detailing for Seattle-area drivers.'
  assign best_for = 'Daily drivers, commuters, families, and vehicles that need a cleaner baseline.'
  assign not_for = 'Heavy pet hair, odor, mold concerns, or restoration-level work without a photo review first.'
  assign included_one = 'Interior surfaces, seats, mats, carpets, glass, and the touchpoints that collect daily grime.'
  assign included_two = 'Exterior hand wash, wheels, tires, glass, trim attention, and a cleaner finish.'
  assign included_three = 'Straight package guidance from Sam before the appointment when the vehicle needs more than the selected tier.'
  assign wash_reason = 'A car wash mostly touches the outside. A detail deals with the parts you actually live with: dusty vents, dirty touchpoints, crumbs, body oils, road film, wheels, glass, and a finish that needs more than a rinse.'
  assign heavy_note = 'If the vehicle is beyond this tier, send photos first. Sam will tell you before you book the wrong appointment.'
  assign faq_time = 'Timing depends on vehicle size, condition, parking access, and add-ons. Sam confirms the appointment window before the detail.'
  assign package_question = 'If you are unsure, send photos. Sam will recommend the lightest package that can still do the job properly.'

  case service_tier
    when 'basic'
      assign headline = 'Basic Mobile Detail for Maintained Cars'
      assign subheadline = 'For vehicles that are already in decent shape and need a clean inside-and-out refresh without booking a heavy reset.'
      assign position = 'Best for maintained vehicles that need a lighter reset.'
      assign best_for = 'Light dust, mild road film, cleaner daily drivers, recent detail customers, and routine upkeep.'
      assign not_for = 'Pet hair packed into carpet, set-in stains, odor, rough paint, or interiors that have been ignored for months.'
      assign included_one = 'Interior wipe-down of touchpoints, plastics, cupholders, glass, mats, and normal dust.'
      assign included_two = 'Exterior hand wash, wheels, tires, exterior glass, and a clean finished look.'
      assign included_three = 'A lighter appointment that keeps a maintained vehicle sharp without charging for work it does not need.'
      assign heavy_note = 'If photos show heavier buildup, Sam will point you to Signature or Elite before you waste the appointment.'
      assign faq_time = 'Basic is the shortest Suds package because it is meant for maintained vehicles. Vehicle size and access still affect the appointment window.'
      assign package_question = 'Choose Basic when the car is already decent and needs upkeep, not a rescue detail.'
    when 'signature'
      assign headline = 'Signature Mobile Detail for Daily Drivers'
      assign subheadline = 'The best first booking for most Seattle-area drivers who want the cabin, exterior, wheels, glass, and daily buildup handled at home or work.'
      assign position = 'Best for most daily drivers that need a proper interior and exterior reset.'
      assign best_for = 'Commuters, family cars, light pet use, normal interior buildup, rain grime, and first-time Suds bookings.'
      assign not_for = 'Severe pet hair, strong odor, heavy staining, mold concerns, or vehicles that clearly need the deepest reset.'
      assign included_one = 'Interior reset for seats, mats, carpets, glass, panels, cupholders, and dirty touchpoints.'
      assign included_two = 'Exterior hand wash, wheels, tires, trim attention, glass, and road film cleanup.'
      assign included_three = 'A strong all-around detail before moving into maintenance or exterior protection.'
      assign heavy_note = 'If the vehicle is rougher than a normal daily-driver reset, Sam may recommend Elite.'
      assign faq_time = 'Signature takes longer than Basic because it goes deeper inside and out. Vehicle size, condition, and add-ons set the final timing.'
      assign package_question = 'Choose Signature if this is your first Suds booking or the vehicle needs a proper daily-driver reset.'
    when 'elite'
      assign headline = 'Elite Mobile Detail for Overdue Vehicles'
      assign subheadline = 'A deeper inside-and-out reset for heavier buildup, family SUVs, pet use, rougher exterior feel, and resale prep.'
      assign position = 'Best for vehicles with heavier buildup, rougher exterior feel, or owners who want the strongest non-coating detail.'
      assign best_for = 'Family SUVs, pet vehicles, heavier daily-driver buildup, resale prep, rougher paint feel, and overdue vehicles.'
      assign not_for = 'Scratch removal guarantees, severe odor guarantees, mold remediation without inspection, or ceramic-level long-term paint protection.'
      assign included_one = 'Deeper interior work for dirty touchpoints, seats, mats, carpets, panels, and built-up grime.'
      assign included_two = 'Exterior hand wash, clay bar decontamination, wheel cleanup, trim attention, glass, and hand wax.'
      assign included_three = 'More time reserved for a stronger visible reset at your home, office, or approved location.'
      assign wash_reason = 'Elite is time and process. It is for the buildup a wash leaves behind: dirty interiors, rough exterior feel, road film, wheel grime, tired gloss, and neglected areas that need more attention.'
      assign heavy_note = 'Pet hair, staining, odor, and neglected condition can change the time required. Photos keep the booking honest.'
      assign faq_time = 'Elite gets the largest appointment window. Vehicle size, pet hair, stains, odor, parking access, and add-ons can change timing.'
      assign package_question = 'Choose Elite if the vehicle feels overdue, needs resale prep, or needs the strongest detail before coating or maintenance.'
  endcase

  assign featured_image = product.featured_image
  assign clean_description_text = product.description | strip_html | strip
  assign show_product_description = true
  if clean_description_text == blank
    assign show_product_description = false
  elsif clean_description_text contains 'WHO THIS IS FOR'
    assign show_product_description = false
  elsif clean_description_text contains 'Who This Is For'
    assign show_product_description = false
  endif

  assign variant_picker_block = blank
  assign buy_buttons_block = blank
  assign has_app_block = false
  for block in section.blocks
    if block.type == 'variant_picker'
      assign variant_picker_block = block
    elsif block.type == 'buy_buttons'
      assign buy_buttons_block = block
    elsif block.type == '@app'
      assign has_app_block = true
    endif
  endfor

  assign basic_product = all_products['basic-detail']
  if basic_product == blank
    assign basic_product = all_products['mini-detail']
  endif
  assign basic_url = '/products/basic-detail'
  if basic_product != blank
    assign basic_url = basic_product.url
  endif

  assign signature_product = all_products['signature-detail']
  if signature_product == blank
    assign signature_product = all_products['interior-detail']
  endif
  assign signature_url = '/products/signature-detail'
  if signature_product != blank
    assign signature_url = signature_product.url
  endif

  assign elite_product = all_products['elite-detail']
  if elite_product == blank
    assign elite_product = all_products['full-detail']
  endif
  assign elite_url = '/products/elite-detail'
  if elite_product != blank
    assign elite_url = elite_product.url
  endif
-%}

{{ 'section-suds-service-product.css' | asset_url | stylesheet_tag }}

<div class="suds-service-product" data-suds-service-product="{{ package_key }}" data-suds-service-tier="{{ service_tier }}">
  <section class="suds-service-hero" id="overview">
    <div class="suds-service-hero__wrap">
      <div class="suds-service-hero__copy">
        <p class="suds-service-hero__eyebrow">Seattle Mobile Detailing</p>
        <h1>{{ headline }}</h1>
        <p class="suds-service-hero__lead">{{ subheadline }}</p>

        <div class="suds-service-proofline">
          <a href="#reviews">Read local reviews</a>
          <span>Mobile at home or office</span>
        </div>

        <div class="suds-service-hero__badges" aria-label="Suds Auto Salon trust signals">
          <span>Detailed by Sam</span>
          <span>Seattle-area routes</span>
          <span>Interior + exterior</span>
          <span>By appointment</span>
        </div>

        <div class="suds-service-booking" id="suds-service-booking-{{ section.id }}">
          <div class="suds-service-booking__price">
            <p>Service price</p>
            {% render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' %}
          </div>
          <p class="suds-service-booking__fit">{{ position }}</p>
          <product-info
            id="ProductInfo-{{ section.id }}"
            data-section="{{ section.id }}"
            data-url="{{ product.url }}"
            class="suds-service-booking__product-info"
          >
            {%- if variant_picker_block != blank -%}
              {% render 'product-variant-picker', product: product, block: variant_picker_block, product_form_id: product_form_id %}
            {%- endif -%}
            {%- if buy_buttons_block != blank -%}
              {% render 'buy-buttons',
                block: buy_buttons_block,
                product: product,
                product_form_id: product_form_id,
                section_id: section.id,
                show_pickup_availability: false,
                force_hide_dynamic_checkout: true,
                button_label: 'Schedule This Detail'
              %}
            {%- endif -%}
          </product-info>
          <div class="suds-service-booking__actions">
            <a href="#compare">Compare Packages</a>
            <a href="/pages/contact-us">Ask About This Package</a>
          </div>
          <p class="suds-service-booking__meta">Mobile appointment service for Seattle and nearby areas.</p>
        </div>
      </div>

      <div class="suds-service-hero-media" aria-label="{{ product.title | escape }} photo gallery">
        <div class="suds-service-hero-media__featured">
          {%- if featured_image != blank -%}
            {%- assign featured_alt = featured_image.alt | default: product.title | escape -%}
            {{
              featured_image
              | image_url: width: 1400
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                widths: '540, 720, 960, 1200, 1400',
                sizes: '(min-width: 990px) 44vw, 100vw',
                alt: featured_alt
            }}
          {%- else -%}
            <div class="suds-service-hero-media__empty">Suds Auto Salon mobile detailing</div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="suds-service-hero-media__thumbs">
            {%- for image in product.images limit: 4 -%}
              {%- assign thumb_alt = image.alt | default: product.title | escape -%}
              <div class="suds-service-hero-media__thumb">
                {{
                  image
                  | image_url: width: 360
                  | image_tag:
                    loading: 'lazy',
                    widths: '160, 240, 360',
                    sizes: '(min-width: 990px) 10vw, 23vw',
                    alt: thumb_alt
                }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <div class="suds-service-hero-media__note">Photos help Sam confirm the right package before the appointment.</div>
      </div>
    </div>
  </section>

  <nav class="suds-service-nav" aria-label="{{ product.title | escape }} page navigation">
    <a href="#overview">Overview</a>
    <a href="#best-for">Best For</a>
    <a href="#included">Included</a>
    <a href="#reviews">Reviews</a>
    <a href="#faq">FAQ</a>
    <a href="#suds-service-booking-{{ section.id }}">Book</a>
  </nav>

  <section class="suds-service-section" id="best-for">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Best fit</p>
        <h2>Book this when the condition matches</h2>
        <p>{{ best_for }}</p>
      </div>
      <div class="suds-service-card-grid">
        <article>
          <h3>Good fit</h3>
          <p>{{ position }}</p>
        </article>
        <article>
          <h3>Skip this if</h3>
          <p>{{ not_for }}</p>
        </article>
        <article>
          <h3>Send photos when</h3>
          <p>{{ heavy_note }}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="included">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Included</p>
        <h2>What gets handled</h2>
        <p>Basic, Signature, and Elite all cover the interior and exterior. The difference is the depth of work and the condition the appointment is built for.</p>
      </div>
      <div class="suds-service-checks">
        <div>{{ included_one }}</div>
        <div>{{ included_two }}</div>
        <div>{{ included_three }}</div>
        <div>Package guidance based on vehicle size, condition, parking access, and your main concerns.</div>
      </div>
      <div class="suds-service-inline-cta">
        <a href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
        <a href="/pages/contact-us">Request a Quote</a>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="value">
    <div class="suds-service-section__wrap suds-service-value">
      <div>
        <p class="suds-service-kicker">Why it costs more</p>
        <h2>Why this is different from a car wash</h2>
      </div>
      <p>{{ wash_reason }}</p>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="results">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Real results</p>
        <h2>Real Suds results</h2>
        <p>Use these photos to judge the kind of finish, cabin cleanup, and exterior presentation this package is meant to deliver.</p>
      </div>
      <div class="suds-service-results-grid">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images limit: 6 -%}
            {%- assign result_alt = image.alt | default: product.title | escape -%}
            <figure>
              {{
                image
                | image_url: width: 720
                | image_tag:
                  loading: 'lazy',
                  widths: '280, 420, 560, 720',
                  sizes: '(min-width: 990px) 31vw, 100vw',
                  alt: result_alt
              }}
            </figure>
          {%- endfor -%}
        {%- else -%}
          <div class="suds-service-results-grid__empty">Add Suds vehicle photos to this product in Shopify to fill this results gallery.</div>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="trust">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Why Suds Auto Salon</p>
        <h2>Detailed by Sam, at your location</h2>
        <p>Suds Auto Salon is a private mobile detailing service. You deal directly with Sam, get the vehicle looked at honestly, and book the level that actually fits the condition.</p>
      </div>
      <div class="suds-service-trust-grid">
        <article><h3>Private appointment</h3><p>One detailer, direct communication, and no volume-shop handoff.</p></article>
        <article><h3>Mobile convenience</h3><p>Home, office, or approved parking location when access and routing work.</p></article>
        <article><h3>Honest package fit</h3><p>If the vehicle needs more or less than this tier, Sam will say so.</p></article>
        <article><h3>Built for the PNW</h3><p>Rain, road film, pets, commuting, outdoor parking, and family use are normal here.</p></article>
      </div>
    </div>
  </section>

  {%- if show_product_description -%}
    <section class="suds-service-section suds-service-description">
      <div class="suds-service-section__wrap">
        <div class="suds-service-section__head">
          <p class="suds-service-kicker">Service details</p>
          <h2>Package notes</h2>
        </div>
        <div class="suds-service-description__body rte">
          {{ product.description }}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="suds-service-section suds-service-section--dark" id="process">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">How booking works</p>
        <h2>How the appointment works</h2>
      </div>
      <div class="suds-service-steps">
        <article><strong>01</strong><h3>Choose the level</h3><p>Pick Basic, Signature, or Elite based on the current condition.</p></article>
        <article><strong>02</strong><h3>Share access details</h3><p>Book online and note parking, water/power access, and anything Sam should know.</p></article>
        <article><strong>03</strong><h3>Sam comes to you</h3><p>The detail is handled at your home, office, or approved location.</p></article>
        <article><strong>04</strong><h3>Keep it clean</h3><p>After the reset, ask about maintenance or protection if it makes sense.</p></article>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="compare">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Compare packages</p>
        <h2>Choose the right level</h2>
        <p>All three are inside-and-out mobile details. Pick by condition, not by guessing from a menu.</p>
      </div>
      <div class="suds-service-package-grid">
        <article class="{% if service_tier == 'basic' %}is-active{% endif %}">
          <span>Basic Detail</span>
          <h3>Light upkeep</h3>
          <p>For maintained vehicles that need a cleaner feel, not a heavy reset.</p>
          <a href="{{ basic_url }}">{% if service_tier == 'basic' %}Book Basic{% else %}View Basic Detail{% endif %}</a>
        </article>
        <article class="{% if service_tier == 'signature' %}is-active{% endif %}">
          <span>Signature Detail</span>
          <h3>Daily-driver reset</h3>
          <p>For most first bookings and normal interior/exterior buildup.</p>
          <a href="{{ signature_url }}">{% if service_tier == 'signature' %}Book Signature{% else %}View Signature Detail{% endif %}</a>
        </article>
        <article class="{% if service_tier == 'elite' %}is-active{% endif %}">
          <span>Elite Detail</span>
          <h3>Deeper reset</h3>
          <p>For overdue vehicles, heavier buildup, pet use, and rougher exterior feel.</p>
          <a href="{{ elite_url }}">{% if service_tier == 'elite' %}Book Elite{% else %}View Elite Detail{% endif %}</a>
        </article>
      </div>
      <div class="suds-service-inline-cta">
        <a href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
        <a href="/pages/contact-us">Ask Which Package Fits</a>
      </div>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="reviews">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Reviews</p>
        <h2>What local customers say</h2>
        <p>Reviews load below through the store review app. Suds also has Google feedback from Seattle-area customers who book Sam for details, coatings, and maintenance.</p>
      </div>
      <div class="suds-service-review-strip" aria-label="Suds Auto Salon customer review excerpts">
        <article>
          <p>"He's very detail oriented and doesn't miss anything."</p>
          <span>Sue Coccia</span>
        </article>
        <article>
          <p>"The car looks showroom-ready and practically sparkles."</p>
          <span>Paul P.</span>
        </article>
        <article>
          <p>"Clear pride and passion for his work."</p>
          <span>Logan Kirkendall</span>
        </article>
      </div>
      {%- if has_app_block -%}
        <div class="suds-service-reviews-app">
          {%- for block in section.blocks -%}
            {%- if block.type == '@app' -%}
              {% render block %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="suds-service-reviews-app">
          <p>Customer reviews load here when the review app block is connected in Shopify.</p>
        </div>
      {%- endif -%}
    </div>
  </section>

  <section class="suds-service-section" id="faq">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">FAQ</p>
        <h2>Questions before you book</h2>
      </div>
      <div class="suds-service-faq">
        <details><summary>How long does this detail take?</summary><p>{{ faq_time }}</p></details>
        <details><summary>Do you come to my location?</summary><p>Yes. Sam details at homes, offices, and approved parking locations when the route and access work.</p></details>
        <details><summary>Is this a maintenance wash?</summary><p>No. This is a detail package. Maintenance is for vehicles that have already been reset and need regular upkeep.</p></details>
        <details><summary>Does this remove scratches?</summary><p>Cleaning, clay, and wax can improve gloss and feel. Actual scratch removal requires paint correction and should be quoted separately.</p></details>
        <details><summary>What if my vehicle has pet hair, stains, or heavy buildup?</summary><p>Send photos before booking. Heavy pet hair, staining, odor, mold concerns, or unusual buildup can require more time or a different package.</p></details>
        <details><summary>What should I remove before the appointment?</summary><p>Remove personal items, valuables, child seats if possible, and anything you do not want moved.</p></details>
        <details><summary>Do I need water or power available?</summary><p>It depends on the location and setup. Share parking and access details when booking so Sam can confirm what is needed.</p></details>
        <details><summary>What package should I choose?</summary><p>{{ package_question }}</p></details>
        <details><summary>Can I add ceramic coating or paint correction?</summary><p>Yes. Coating and correction are separate upgrades and should be quoted after Sam sees the paint condition and your protection goals.</p></details>
      </div>
    </div>
  </section>

  <section class="suds-service-final" id="book">
    <div class="suds-service-final__wrap">
      <h2>Ready to get your vehicle back in shape?</h2>
      <p>Schedule the detail, or send photos first if you want Sam to confirm the right package before you book.</p>
      <div class="suds-service-final__actions">
        <a href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
        <a href="/pages/contact-us">Request a Quote</a>
        <a href="sms:+14253618838">Text Photos for a Faster Quote</a>
      </div>
    </div>
  </section>

  <a class="suds-service-sticky" href="#suds-service-booking-{{ section.id }}">Schedule This Detail</a>
</div>

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
-%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {% if seo_media -%}
      "image": [
        {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
      ],
    {%- endif %}
    "description": {{ product.description | strip_html | default: subheadline | json }},
    {% if product.selected_or_first_available_variant.sku != blank -%}
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "offers": [
      {%- for variant in product.variants -%}
        {
          "@type" : "Offer",
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
          "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
          "price" : {{ variant.price | divided_by: 100.00 | json }},
          "priceCurrency" : {{ cart.currency.iso_code | json }},
          "url" : {{ request.origin | append: variant.url | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does this mobile detail take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq_time | json }}
      }
    },
    {
      "@type": "Question",
      "name": "Do you come to my location?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Sam details at homes, offices, and approved parking locations when the route and access work."
      }
    },
    {
      "@type": "Question",
