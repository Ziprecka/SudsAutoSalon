{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign package_key = product.handle
  assign service_tier = 'custom'

  case product.handle
    when 'basic-detail', 'mini-detail'
      assign service_tier = 'basic'
    when 'signature-detail', 'interior-detail'
      assign service_tier = 'signature'
    when 'elite-detail', 'full-detail'
      assign service_tier = 'elite'
  endcase

  assign lower_product_title = product.title | downcase
  if service_tier == 'custom'
    if lower_product_title contains 'basic detail'
      assign service_tier = 'basic'
    elsif lower_product_title contains 'mini detail'
      assign service_tier = 'basic'
    elsif lower_product_title contains 'signature detail'
      assign service_tier = 'signature'
    elsif lower_product_title contains 'interior detail'
      assign service_tier = 'signature'
    elsif lower_product_title contains 'elite detail'
      assign service_tier = 'elite'
    elsif lower_product_title contains 'full detail'
      assign service_tier = 'elite'
    endif
  endif

  assign headline = product.title | append: ' Mobile Detail'
  assign subheadline = 'Private mobile detailing at your home or office. Schedule the package that fits your vehicle, with quote help available when condition concerns may change the right detail.'
  assign position = 'Inside-and-out mobile detailing for Seattle-area drivers.'
  assign best_for_items = 'Daily drivers|Commuters|Family vehicles|Vehicles that need a cleaner baseline'
  assign interior_title = 'Interior Detail'
  assign interior_items = 'Interior surfaces and touchpoints|Seats, mats, carpets, and glass|Dust, crumbs, and daily grime'
  assign exterior_title = 'Exterior Detail'
  assign exterior_items = 'Exterior hand wash|Wheels, tires, and glass|A cleaner finish and sharper presentation'
  assign positioning_note = 'If the vehicle needs more or less than the package selected, Sam can help point you in the right direction.'
  assign wash_reason = 'A car wash cleans the surface. A real detail addresses the buildup that comes from actually driving the vehicle: interior grime, dust, crumbs, body oils, road film, dirty wheels, contaminated paint, and tired finishes. You are not paying for a quick rinse. You are paying for time, process, and a vehicle that feels cleaner, sharper, and easier to maintain.'
  assign faq_time = 'Timing depends on the vehicle size, package, and condition. Heavier buildup, pet hair, staining, and add-ons can increase service time.'
  assign package_question = 'If your vehicle is already maintained, Basic may be enough. If it needs a proper inside-and-out reset, start with Signature. If it has heavier buildup, pet mess, rough paint, or resale prep needs, Elite is usually the better fit.'
  assign final_heading = 'Ready for a cleaner vehicle?'
  assign final_copy = 'Schedule the detail that fits your vehicle, or request a quote if you want help choosing the right starting point.'
  assign active_button_label = 'Schedule This Detail'

  case service_tier
    when 'basic'
      assign headline = 'A Lighter Mobile Detail for Maintained Vehicles'
      assign subheadline = 'The Basic Detail is built for vehicles that already stay fairly clean but need a professional interior and exterior refresh at your home or office.'
      assign position = 'Clean upkeep for maintained vehicles.'
      assign best_for_items = 'Maintained daily drivers|Vehicles that need a lighter cleanup|Customers who want a simple refresh|Regular upkeep between deeper details|Cars without heavy pet hair, staining, or buildup'
      assign interior_title = 'Interior Refresh'
      assign interior_items = 'Light vacuum of main interior areas|Wipe-down of common touchpoints|Interior glass cleaning|Basic surface refresh for a cleaner cabin'
      assign exterior_title = 'Exterior Refresh'
      assign exterior_items = 'Hand wash and dry|Wheel and tire face cleaning|Exterior glass cleaning|Light finish wipe-down'
      assign positioning_note = 'This is not the right package for heavy buildup, severe pet hair, deep stains, or neglected vehicles. For a stronger reset, choose Signature or Elite.'
      assign faq_time = 'Basic is a lighter appointment for maintained vehicles. Vehicle size, access, and condition still affect the appointment window.'
      assign final_heading = 'Ready for a cleaner daily driver?'
      assign final_copy = 'Schedule the Basic Detail for a lighter mobile refresh at your home or office.'
      assign active_button_label = 'Schedule Basic Detail'
    when 'signature'
      assign headline = 'The Best First Booking for Most Daily Drivers'
      assign subheadline = 'The Signature Detail is a full interior and exterior mobile detail for Seattle-area drivers who want their vehicle cleaned properly inside and out without wasting time at a shop.'
      assign position = 'The best first booking for most daily drivers.'
      assign best_for_items = 'Most daily drivers|Vehicles with normal interior buildup|Owners who want a proper inside-and-out reset|Busy drivers who want mobile service at home or work|Customers unsure where to start'
      assign interior_title = 'Interior Reset'
      assign interior_items = 'Full interior vacuum|Cleaning of plastics, panels, cupholders, console, and touchpoints|Upholstery and carpet cleaning for normal buildup|Interior glass cleaning|Final interior wipe-down for a cleaner, fresher cabin'
      assign exterior_title = 'Exterior Reset'
      assign exterior_items = 'Careful hand wash and dry|Wheel and tire cleaning|Exterior glass cleaning|Paint-safe finish care|Final exterior wipe-down for a sharper presentation'
      assign positioning_note = 'Signature is the recommended starting point for most vehicles. If the vehicle has heavier buildup, rough paint, pet mess, or resale prep needs, Elite may be the better fit.'
      assign faq_time = 'Signature usually takes longer than Basic because it goes deeper inside and out. Vehicle size, condition, access, and add-ons set the final timing.'
      assign final_heading = 'Ready for your vehicle to feel clean again?'
      assign final_copy = 'Schedule the Signature Detail for the best first reset for most Seattle-area drivers.'
      assign active_button_label = 'Schedule Signature Detail'
    when 'elite'
      assign headline = 'Seattle Mobile Detailing for Cars That Need a Real Reset'
      assign subheadline = 'The Elite Detail is a premium interior and exterior mobile detail for Seattle drivers who want their vehicle cleaned properly &mdash; not rushed through a basic wash.'
      assign position = 'A premium reset for heavier buildup.'
      assign best_for_items = 'Vehicles with heavier daily-driver buildup|Family vehicles, pet vehicles, and work vehicles|Owners preparing to sell or trade in|Interiors that feel overdue for a deep clean|Exterior paint that feels rough, dull, or contaminated|Drivers who want the strongest non-coating detail'
      assign interior_title = 'Interior Deep Reset'
      assign interior_items = 'Full interior vacuum of floors, seats, cargo areas, cracks, and reachable crevices|Deep cleaning of plastics, panels, cupholders, console, vents, and high-touch areas|Upholstery and carpet cleaning for normal buildup, grime, and light staining|Interior glass cleaning for a clear, streak-free finish|Final interior wipe-down and finishing touches'
      assign exterior_title = 'Exterior Deep Reset'
      assign exterior_items = 'Careful hand wash to remove dirt, grime, and road film|Wheel, tire, and wheel-face cleaning|Clay bar treatment to remove bonded surface contamination|Premium hand wax for gloss, slickness, and short-term protection|Final exterior touch-up for a cleaner, sharper finish'
      assign positioning_note = 'Elite is built for a stronger transformation than a basic wash or light refresh. For scratch removal, oxidation correction, or long-term protection, ask about paint correction or ceramic coating.'
      assign faq_time = 'Elite gets the largest appointment window. Vehicle size, pet hair, stains, odor, parking access, and add-ons can change timing.'
      assign final_heading = 'Ready for a real reset?'
      assign final_copy = 'Schedule the Elite Detail for a deeper interior and exterior mobile detail built for heavier buildup and stronger transformation.'
      assign active_button_label = 'Schedule Elite Detail'
  endcase

  assign best_for_list = best_for_items | split: '|'
  assign interior_list = interior_items | split: '|'
  assign exterior_list = exterior_items | split: '|'

  assign featured_image = product.featured_image
  assign wheel_service_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_b52468ed-4ba5-4ee9-94ba-541c2b16683b.jpg?v=1779266082'
  assign paint_towel_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_c2f80beb-6530-4420-8472-a92faccbe0f9.jpg?v=1779266080'
  assign steam_interior_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_fcc641e4-314c-48e8-ad61-9ecdacfcecd9.jpg?v=1779266078'
  assign door_detail_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_ad58bc49-9ae2-42c1-8558-4cf7ea1be591.jpg?v=1779266059'
  assign wheel_towel_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_9cb5a499-13f3-42cd-a162-7b3e5d9b0269.jpg?v=1779266058'
  assign polisher_image_url = 'https://images.pexels.com/photos/5233258/pexels-photo-5233258.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign elite_polish_hero_image_url = 'https://images.pexels.com/photos/5233259/pexels-photo-5233259.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign vacuum_interior_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6648c2c3-acdf-423f-b835-b6e7f93d2e14.jpg?v=1779266055'
  assign console_brush_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6ecb2b24-4ebc-4baa-872d-352805ac81a7.jpg?v=1779266049'
  assign red_protection_image_url = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download.jpg?v=1779266040'
  assign basic_service_image_url = vacuum_interior_image_url
  assign signature_service_image_url = console_brush_image_url
  assign elite_service_image_url = polisher_image_url
  assign finish_service_image_url = red_protection_image_url
  assign cabin_service_image_url = steam_interior_image_url
  assign basic_hero_image_url = 'https://images.pexels.com/photos/5288711/pexels-photo-5288711.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign signature_hero_image_url = 'https://images.pexels.com/photos/4870727/pexels-photo-4870727.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign elite_hero_image_url = elite_polish_hero_image_url
  assign service_image_url = ''
  assign hero_image_url = ''
  assign service_image_alt = product.title | append: ' mobile detailing service'
  case service_tier
    when 'basic'
      assign service_image_url = basic_service_image_url
      assign hero_image_url = basic_hero_image_url
      assign service_image_alt = 'Interior vacuum detail work for Basic Detail upkeep'
    when 'signature'
      assign service_image_url = signature_service_image_url
      assign hero_image_url = signature_hero_image_url
      assign service_image_alt = 'Interior console brush cleaning for Signature Detail'
    when 'elite'
      assign service_image_url = elite_service_image_url
      assign hero_image_url = elite_hero_image_url
      assign service_image_alt = 'Machine polish work for Elite Detail mobile service'
  endcase
  if hero_image_url == blank
    assign hero_image_url = service_image_url
  endif
  assign clean_description_text = product.description | strip_html | strip
  assign show_product_description = true
  if clean_description_text == blank
    assign show_product_description = false
  elsif clean_description_text contains 'WHO THIS IS FOR'
    assign show_product_description = false
  elsif clean_description_text contains 'Who This Is For'
    assign show_product_description = false
  endif
  if service_tier == 'basic' or service_tier == 'signature' or service_tier == 'elite'
    assign show_product_description = false
  endif

  assign variant_picker_block = blank
  assign buy_buttons_block = blank
  for block in section.blocks
    if block.type == 'variant_picker'
      assign variant_picker_block = block
    elsif block.type == 'buy_buttons'
      assign buy_buttons_block = block
    endif
  endfor

  assign basic_product = all_products['basic-detail']
  if basic_product == blank
    assign basic_product = all_products['mini-detail']
  endif
  assign basic_url = '/products/basic-detail'
  if basic_product != blank
    assign basic_url = basic_product.url
  endif

  assign signature_product = all_products['signature-detail']
  if signature_product == blank
    assign signature_product = all_products['interior-detail']
  endif
  assign signature_url = '/products/signature-detail'
  if signature_product != blank
    assign signature_url = signature_product.url
  endif

  assign elite_product = all_products['elite-detail']
  if elite_product == blank
    assign elite_product = all_products['full-detail']
  endif
  assign elite_url = '/products/elite-detail'
  if elite_product != blank
    assign elite_url = elite_product.url
  endif

  assign ceramic_url = '/pages/ceramic-coating'
  assign ceramic_product = all_products['ceramic-coating']
  if ceramic_product != blank
    assign ceramic_url = ceramic_product.url
  endif
-%}

{{ 'section-suds-service-product.css' | asset_url | stylesheet_tag }}

<div class="suds-service-product" data-suds-service-product="{{ package_key }}" data-suds-service-tier="{{ service_tier }}">
  <section class="suds-service-package-stage" id="suds-service-packages">
    <div class="suds-service-section__wrap">
      <div class="suds-service-package-stage__head">
        <p class="suds-service-package-stage__eyebrow">Seattle Mobile Detailing</p>
        <h1>Compare Detail Packages</h1>
        <p>Choose the package that matches your vehicle's condition. The current package is highlighted with the booking button ready inside the card.</p>
        {% render 'suds-judgeme-widgets', widget: 'product_badge', product: product, review_link: '#reviews' %}
        <div class="suds-service-package-stage__badges" aria-label="Suds Auto Salon trust signals">
          <span>Mobile at home or office</span>
          <span>Interior + exterior packages</span>
          <span>Private Seattle-area detailer</span>
          <span>Book online when you know the package</span>
        </div>
      </div>
      <div class="suds-service-premium-grid">
        <article class="suds-service-premium-card {% if service_tier == 'basic' %}is-active{% endif %}">
          <div class="suds-service-premium-card__media">
            <img src="{{ basic_service_image_url }}" loading="lazy" alt="Interior vacuum work for Basic Detail upkeep">
          </div>
          <div class="suds-service-premium-card__body">
            <p class="suds-service-premium-card__label">Lighter upkeep refresh</p>
            <h3>Basic Detail</h3>
            {%- if basic_product != blank -%}<p class="suds-service-premium-card__price">Starting at {{ basic_product.price | money_without_trailing_zeros }}</p>{%- endif -%}
            <ul>
              <li>For maintained vehicles</li>
              <li>Lighter interior refresh</li>
              <li>Hand wash and dry</li>
              <li>Wheel and tire faces</li>
              <li>Interior and exterior glass</li>
              <li>Cleaner, fresher feel</li>
            </ul>
            {%- if service_tier == 'basic' -%}
              <div class="suds-service-booking" id="suds-service-booking-{{ section.id }}">
                <div class="suds-service-booking__price">
                  <p>Service price</p>
                  {% render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' %}
                </div>
                <p class="suds-service-booking__fit">{{ position }}</p>
                <product-info id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}" class="suds-service-booking__product-info">
                  {%- if variant_picker_block != blank -%}
                    {% render 'product-variant-picker', product: product, block: variant_picker_block, product_form_id: product_form_id %}
                  {%- endif -%}
                  {%- if buy_buttons_block != blank -%}
                    {% render 'buy-buttons', block: buy_buttons_block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: false, force_hide_dynamic_checkout: true, button_label: active_button_label %}
                  {%- endif -%}
                </product-info>
              </div>
            {%- else -%}
              <a class="suds-service-premium-card__button" href="{{ basic_url }}">View Basic Detail</a>
            {%- endif -%}
          </div>
        </article>

        <article class="suds-service-premium-card {% if service_tier == 'signature' %}is-active{% endif %}">
          <div class="suds-service-premium-card__media">
            <img src="{{ signature_service_image_url }}" loading="lazy" alt="Interior console detail brush work for Signature Detail">
          </div>
          <div class="suds-service-premium-card__body">
            <p class="suds-service-premium-card__label">Best first booking</p>
            <h3>Signature Detail</h3>
            {%- if signature_product != blank -%}<p class="suds-service-premium-card__price">Starting at {{ signature_product.price | money_without_trailing_zeros }}</p>{%- endif -%}
            <ul>
              <li>For most daily drivers</li>
              <li>Proper inside-and-out reset</li>
              <li>Full interior vacuum</li>
              <li>Touchpoint and panel cleaning</li>
              <li>Careful hand wash</li>
              <li>Sharper exterior presentation</li>
            </ul>
            {%- if service_tier == 'signature' -%}
              <div class="suds-service-booking" id="suds-service-booking-{{ section.id }}">
                <div class="suds-service-booking__price">
                  <p>Service price</p>
                  {% render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' %}
                </div>
                <p class="suds-service-booking__fit">{{ position }}</p>
                <product-info id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}" class="suds-service-booking__product-info">
                  {%- if variant_picker_block != blank -%}
                    {% render 'product-variant-picker', product: product, block: variant_picker_block, product_form_id: product_form_id %}
                  {%- endif -%}
                  {%- if buy_buttons_block != blank -%}
                    {% render 'buy-buttons', block: buy_buttons_block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: false, force_hide_dynamic_checkout: true, button_label: active_button_label %}
                  {%- endif -%}
                </product-info>
              </div>
            {%- else -%}
              <a class="suds-service-premium-card__button" href="{{ signature_url }}">View Signature Detail</a>
            {%- endif -%}
          </div>
        </article>

        <article class="suds-service-premium-card {% if service_tier == 'elite' %}is-active{% endif %}">
          <div class="suds-service-premium-card__media">
            <img src="{{ elite_service_image_url }}" loading="lazy" alt="Paint polishing for Elite Detail">
          </div>
          <div class="suds-service-premium-card__body">
            <p class="suds-service-premium-card__label">Premium deep reset</p>
            <h3>Elite Detail</h3>
            {%- if elite_product != blank -%}<p class="suds-service-premium-card__price">Starting at {{ elite_product.price | money_without_trailing_zeros }}</p>{%- endif -%}
            <ul>
              <li>For heavier buildup</li>
              <li>Family, pet, and work vehicles</li>
              <li>Deeper interior reset</li>
              <li>Clay bar decontamination</li>
              <li>Premium hand wax</li>
              <li>Strongest non-coating detail</li>
            </ul>
            {%- if service_tier == 'elite' -%}
              <div class="suds-service-booking" id="suds-service-booking-{{ section.id }}">
                <div class="suds-service-booking__price">
                  <p>Service price</p>
                  {% render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' %}
                </div>
                <p class="suds-service-booking__fit">{{ position }}</p>
                <product-info id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}" class="suds-service-booking__product-info">
                  {%- if variant_picker_block != blank -%}
                    {% render 'product-variant-picker', product: product, block: variant_picker_block, product_form_id: product_form_id %}
                  {%- endif -%}
                  {%- if buy_buttons_block != blank -%}
                    {% render 'buy-buttons', block: buy_buttons_block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: false, force_hide_dynamic_checkout: true, button_label: active_button_label %}
                  {%- endif -%}
                </product-info>
              </div>
            {%- else -%}
              <a class="suds-service-premium-card__button" href="{{ elite_url }}">View Elite Detail</a>
            {%- endif -%}
          </div>
        </article>

        <article class="suds-service-premium-card">
          <div class="suds-service-premium-card__media">
            <img src="{{ red_protection_image_url }}" loading="lazy" alt="Ceramic coating application for longer-lasting gloss and protection">
          </div>
          <div class="suds-service-premium-card__body">
            <p class="suds-service-premium-card__label">Protection upgrade</p>
            <h3>Ceramic Coating</h3>
            <ul>
              <li>Longer-lasting than wax</li>
              <li>Gloss and slickness</li>
              <li>Easier maintenance washing</li>
              <li>Proper prep before coating</li>
              <li>Best after a reset</li>
              <li>Quoted by paint condition</li>
            </ul>
            <a class="suds-service-premium-card__button" href="{{ ceramic_url }}">View Ceramic Coating</a>
          </div>
        </article>
      </div>
      <p class="suds-service-package-stage__note">Schedule directly when you know the package. Request a quote if pet hair, odor, staining, access, or paint condition may change the right recommendation.</p>
    </div>
  </section>

  <nav class="suds-service-nav" aria-label="{{ product.title | escape }} page navigation">
    <a href="#suds-service-packages">Packages</a>
    <a href="#best-for">Best For</a>
    <a href="#included">Included</a>
    <a href="#value">Value</a>
    <a href="#reviews">Reviews</a>
    <a href="#faq">FAQ</a>
    <a href="#suds-service-booking-{{ section.id }}">Book</a>
  </nav>

  <section class="suds-service-section" id="best-for">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Best For</p>
        <h2>Who this detail is for</h2>
        <p>{{ position }}</p>
      </div>
      <div class="suds-service-card-grid suds-service-card-grid--two">
        <article>
          <h3>Best for</h3>
          <ul>
            {%- for item in best_for_list -%}
              <li>{{ item }}</li>
            {%- endfor -%}
          </ul>
        </article>
        <article>
          <h3>Package note</h3>
          <p>{{ positioning_note }}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="included">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Included</p>
        <h2>What's included</h2>
        <p>Each Suds package covers the interior and exterior. The right choice depends on the vehicle's condition, the time required, and how deep the reset needs to go.</p>
      </div>
      <div class="suds-service-included-grid">
        <article>
          <h3>{{ interior_title }}</h3>
          <ul>
            {%- for item in interior_list -%}
              <li>{{ item }}</li>
            {%- endfor -%}
          </ul>
        </article>
        <article>
          <h3>{{ exterior_title }}</h3>
          <ul>
            {%- for item in exterior_list -%}
              <li>{{ item }}</li>
            {%- endfor -%}
          </ul>
        </article>
      </div>
      <div class="suds-service-inline-cta">
        <a href="#suds-service-booking-{{ section.id }}">{{ active_button_label }}</a>
        <a href="/pages/contact-us">Request a Quote</a>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="value">
    <div class="suds-service-section__wrap suds-service-value">
      <div>
        <p class="suds-service-kicker">Detail vs. wash</p>
        <h2>Why This Costs More Than a Car Wash</h2>
      </div>
      <p>{{ wash_reason }}</p>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="results">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Real results</p>
        <h2>Real Results</h2>
        <p>Interior and exterior detailing should make the vehicle feel cleaner, sharper, and easier to keep up with after the appointment.</p>
      </div>
      <div class="suds-service-results-grid">
        <figure><img src="{{ service_image_url }}" loading="lazy" alt="{{ service_image_alt | escape }}"></figure>
        <figure><img src="{{ cabin_service_image_url }}" loading="lazy" alt="Steam cleaning an interior door panel during mobile detailing"></figure>
        <figure><img src="{{ finish_service_image_url }}" loading="lazy" alt="Applying protection to glossy red vehicle paint"></figure>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="trust">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Why Suds Auto Salon</p>
        <h2>Why Book With Suds Auto Salon?</h2>
        <p>Suds Auto Salon is a private mobile detailing service built around careful work, direct communication, and recommendations that match the vehicle in front of Sam.</p>
      </div>
      <div class="suds-service-trust-grid">
        <article><h3>Private Mobile Service</h3><p>Your vehicle gets focused attention instead of assembly-line treatment.</p></article>
        <article><h3>Service at Your Location</h3><p>Suds comes to your home, office, or approved service location in the Seattle area.</p></article>
        <article><h3>Condition-Based Recommendations</h3><p>If your vehicle needs more or less than the package you selected, Sam can help point you in the right direction.</p></article>
        <article><h3>Interior + Exterior Focus</h3><p>Packages are built around the way real vehicles get dirty: cabins, carpets, touchpoints, wheels, paint, and finish.</p></article>
        <article><h3>Review-Backed Local Business</h3><p>Suds is built on careful work, direct communication, and trust with Seattle-area drivers.</p></article>
      </div>
    </div>
  </section>

  {%- if show_product_description -%}
    <section class="suds-service-section suds-service-description">
      <div class="suds-service-section__wrap">
        <div class="suds-service-section__head">
          <p class="suds-service-kicker">Service details</p>
          <h2>Package notes</h2>
        </div>
        <div class="suds-service-description__body rte">
          {{ product.description }}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="suds-service-section suds-service-section--dark" id="process">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Booking</p>
        <h2>How mobile detailing works</h2>
      </div>
      <div class="suds-service-steps">
        <article><strong>01</strong><h3>Choose the detail</h3><p>Start with the package that best matches your vehicle's condition.</p></article>
        <article><strong>02</strong><h3>Schedule online</h3><p>Book the mobile appointment and share any access notes Sam should know.</p></article>
        <article><strong>03</strong><h3>Suds comes to you</h3><p>The detail is handled at your home, office, or approved service location.</p></article>
        <article><strong>04</strong><h3>Keep it clean</h3><p>After the reset, ask about maintenance, paint enhancement, or ceramic protection if it fits your goals.</p></article>
      </div>
    </div>
  </section>

  <section class="suds-service-section suds-service-section--cream" id="reviews">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">Reviews</p>
        <h2>Reviewed by Seattle-area drivers</h2>
        <p>Customer reviews help show the real Suds experience: careful work, mobile convenience, and drivers who book again.</p>
      </div>
      {% render 'suds-judgeme-widgets',
        widget: 'product_widget',
        product: product,
        heading: 'Reviews for this detail',
        subheading: 'Current customer reviews appear here when available for this package.'
      %}
      {% render 'suds-judgeme-widgets',
        widget: 'carousel',
        heading: 'More Google reviews from Suds customers',
        subheading: 'Recent customer feedback from Google.'
      %}
      <div class="suds-service-review-strip" aria-label="Suds Auto Salon customer review excerpts">
        <article>
          <p>"He's very detail oriented and doesn't miss anything."</p>
          <span>Sue Coccia</span>
        </article>
        <article>
          <p>"The car looks showroom-ready and practically sparkles."</p>
          <span>Paul P.</span>
        </article>
        <article>
          <p>"Clear pride and passion for his work."</p>
          <span>Logan Kirkendall</span>
        </article>
      </div>
    </div>
  </section>

  <section class="suds-service-section" id="faq">
    <div class="suds-service-section__wrap">
      <div class="suds-service-section__head">
        <p class="suds-service-kicker">FAQ</p>
        <h2>Questions before you book</h2>
      </div>
      <div class="suds-service-faq">
        <details><summary>Which detail should I book?</summary><p>{{ package_question }}</p></details>
        <details><summary>Do you come to my home or office?</summary><p>Yes. Suds Auto Salon provides mobile detailing at homes, offices, apartments, and approved service locations across the Seattle area.</p></details>
        <details><summary>Do I need to send photos?</summary><p>Photos help recommend the right package and avoid surprises. Send clear photos of the interior, exterior, problem areas, and anything you want addressed.</p></details>
        <details><summary>Does detailing remove scratches?</summary><p>Cleaning, clay bar treatment, and wax can improve gloss and surface feel, but true scratch removal requires polishing or paint correction.</p></details>
        <details><summary>Do you remove stains?</summary><p>Light staining and normal buildup can often be improved, but severe or permanent staining may not fully come out.</p></details>
        <details><summary>Do you remove pet hair?</summary><p>Pet hair can usually be improved, but heavy embedded pet hair may require additional time or an add-on.</p></details>
        <details><summary>Do you offer ceramic coating?</summary><p>Yes. Ceramic coating is available as a protection upgrade for customers who want longer-lasting gloss, slickness, and easier maintenance.</p></details>
        <details><summary>Is this a car wash?</summary><p>No. Suds offers mobile detailing packages built around more thorough interior and exterior cleaning than a basic wash.</p></details>
        <details><summary>How long does a detail take?</summary><p>{{ faq_time }}</p></details>
        <details><summary>Do you need water or power?</summary><p>Availability of water or power may depend on the appointment location and service selected. Send your address or location details when requesting a quote.</p></details>
      </div>
    </div>
  </section>

  <section class="suds-service-final" id="book">
    <div class="suds-service-final__wrap">
      <h2>{{ final_heading }}</h2>
      <p>{{ final_copy }}</p>
      <div class="suds-service-final__actions">
        <a href="#suds-service-booking-{{ section.id }}">{{ active_button_label }}</a>
        <a href="/pages/contact-us">Request a Quote</a>
      </div>
    </div>
  </section>

  <a class="suds-service-sticky" href="#suds-service-booking-{{ section.id }}">{{ active_button_label }}</a>
</div>

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
-%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    {% if seo_media -%}
      "image": [
        {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
      ],
    {%- endif %}
    "description": {{ subheadline | strip_html | json }},
    {% if product.selected_or_first_available_variant.sku != blank -%}
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "offers": [
      {%- for variant in product.variants -%}
        {
          "@type" : "Offer",
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
          "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
          "price" : {{ variant.price | divided_by: 100.00 | json }},
          "priceCurrency" : {{ cart.currency.iso_code | json }},
          "url" : {{ request.origin | append: variant.url | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ product.title | append: " mobile detailing" | json }},
  "serviceType": "Mobile car detailing",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Suds Auto Salon",
    "url": {{ shop.url | json }},
    "telephone": "+1-425-361-8838"
  },
  "areaServed": [
    "Seattle, WA",
    "Bellevue, WA",
    "Edmonds, WA",
    "Lynnwood, WA",
    "Everett, WA",
    "Marysville, WA",
    "Lake Stevens, WA",
    "Snohomish, WA"
  ],
  "description": {{ subheadline | strip_html | json }},
  "offers": {
    "@type": "Offer",
    "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "availability": "https://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ request.origin | append: product.url | json }}
  }
}
</script>

