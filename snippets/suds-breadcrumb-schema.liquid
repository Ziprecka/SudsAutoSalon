{%- if request.page_type == 'page' or request.page_type == 'product' or request.page_type == 'collection' -%}
  {%- liquid
    assign item_name = page.title | default: product.title | default: collection.title | default: shop.name
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ shop.url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ item_name | json }},
        "item": "{{ canonical_url }}"
      }
    ]
  }
  </script>
{%- endif -%}
