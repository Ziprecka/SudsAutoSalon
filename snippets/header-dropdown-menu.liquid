{% comment %}
  Suds primary desktop navigation. Landing pages do the selling; Book Now routes to checkout products.
{% endcomment %}

{%- assign suds_nav = 'Home|/|Services|/pages/services|Packages|/#packages|Gallery|/#gallery|Reviews|/pages/reviews|Service Areas|/pages/service-areas|Contact|/pages/contact-us|Book Now|/collections/mobile-details' | split: '|' -%}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for item in suds_nav -%}
      {%- assign mod = forloop.index0 | modulo: 2 -%}
      {%- if mod == 0 -%}
        {%- assign label = item -%}
        {%- assign url = suds_nav[forloop.index] -%}
        <li>
          <a
            id="HeaderMenu-suds-{{ label | handleize }}"
            href="{{ url }}"
            class="header__menu-item list-menu__item link link--text focus-inset{% if label == 'Book Now' %} header__menu-item--suds-book{% endif %}{% if request.path == url %} header__active-menu-item{% endif %}"
            {% if request.path == url %}
              aria-current="page"
            {% endif %}
          >
            <span>{{ label }}</span>
          </a>
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</nav>
