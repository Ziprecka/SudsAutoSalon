{%- liquid
  assign widget_type = widget | default: 'carousel'
  assign review_heading = heading | default: ''
  assign review_subheading = subheading | default: ''
  assign review_link = review_link | default: '#reviews'
  assign review_product = product
  assign judge_shop = shop.metafields.judgeme
  assign compact_reviews = compact | default: false
-%}

{%- case widget_type -%}
  {%- when 'product_badge' -%}
    {%- if review_product != blank -%}
      <div class="suds-jdgm-badge">
        <div class="jdgm-widget jdgm-preview-badge" data-id="{{ review_product.id }}">
          {{ review_product.metafields.judgeme.badge }}
        </div>
        <a href="{{ review_link }}">Read local reviews</a>
      </div>
    {%- endif -%}

  {%- when 'product_widget' -%}
    {%- if review_product != blank -%}
      {%- liquid
        assign has_product_legacy = false
        if review_product.metafields.judgeme.widget.size > 20
          assign has_product_legacy = true
        endif
        assign has_product_data = false
        if review_product.metafields.judgeme.review_widget_data != blank
          assign has_product_data = true
        endif
      -%}
      {%- if has_product_legacy or has_product_data -%}
        <div class="suds-jdgm-widget suds-jdgm-widget--product">
          {%- if review_heading != blank or review_subheading != blank -%}
            <div class="suds-jdgm-widget__head">
              {%- if review_heading != blank -%}<h3>{{ review_heading }}</h3>{%- endif -%}
              {%- if review_subheading != blank -%}<p>{{ review_subheading }}</p>{%- endif -%}
            </div>
          {%- endif -%}
          <div class="suds-jdgm-widget__body">
            <div
              id="judgeme_product_reviews"
              class="jdgm-widget jdgm-review-widget"
              data-id="{{ review_product.id }}"
              data-product-id="{{ review_product.id }}"
              data-product-title="{{ review_product.title | escape }}"
              data-widget="review"
              data-auto-install="false"
              data-shop-reviews-count="{{ judge_shop.shop_reviews_count | default: 0 | escape }}"
              data-entry-point="review_widget.js"
              data-entry-key="review-widget/main.js"
            >
              {%- if has_product_legacy -%}
                <div class="jdgm-legacy-widget-content" style="display: none;">{{ review_product.metafields.judgeme.widget }}</div>
              {%- endif -%}
            </div>
            {%- if has_product_data -%}
              <script>
                window.jdgm = window.jdgm || {};
                window.jdgm.data = window.jdgm.data || {};
                window.jdgm.data.reviewWidget = window.jdgm.data.reviewWidget || {};
                window.jdgm.data.reviewWidget[{{ review_product.id }}] = {{ review_product.metafields.judgeme.review_widget_data }};
              </script>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

  {%- when 'all_reviews' -%}
    {%- liquid
      assign has_legacy_reviews = false
      if judge_shop.all_reviews_header != blank
        assign has_legacy_reviews = true
      endif
      assign has_v2025_reviews = false
      if judge_shop.all_reviews_widget_v2025_data != blank
        assign has_v2025_reviews = true
      endif
    -%}
    {%- if has_legacy_reviews or has_v2025_reviews -%}
      <div class="suds-jdgm-widget suds-jdgm-widget--all-reviews{% if compact_reviews %} suds-jdgm-widget--compact-reviews{% endif %}">
        {%- if review_heading != blank or review_subheading != blank -%}
          <div class="suds-jdgm-widget__head">
            {%- if review_heading != blank -%}<h3>{{ review_heading }}</h3>{%- endif -%}
            {%- if review_subheading != blank -%}<p>{{ review_subheading }}</p>{%- endif -%}
          </div>
        {%- endif -%}
        <div
          class="jdgm-widget jdgm-all-reviews-widget-v2025"
          data-widget="all-reviews-v2025"
          data-auto-install="false"
          data-entry-point="all_reviews_widget_v2025.js"
          data-entry-key="all-reviews-widget-v2025/main.js"
        >
          {%- if has_legacy_reviews -%}
            <div class="jdgm-legacy-widget-content" style="display: none;">
              <article class="jdgm-widget jdgm-all-reviews-widget">
                <style class="jdgm-temp-hiding-style">.jdgm-all-reviews-widget { display: none; }</style>
                {{ judge_shop.all_reviews_header }}
                <div class="jdgm-all-reviews__body">
                  {%- for i in (0..65535) -%}
                    {%- assign review_key = 'all_reviews_' | append: i -%}
                    {%- assign review_markup = judge_shop[review_key] -%}
                    {%- if review_markup == blank -%}
                      {%- break -%}
                    {%- endif -%}
                    {{ review_markup }}
                  {%- endfor -%}
                </div>
              </article>
            </div>
          {%- endif -%}
        </div>
        {%- if has_v2025_reviews -%}
          <script>
            window.jdgm = window.jdgm || {};
            window.jdgm.data = window.jdgm.data || {};
            window.jdgm.data.allReviewsWidgetV2025 = {{ judge_shop.all_reviews_widget_v2025_data }};
          </script>
        {%- endif -%}
      </div>
    {%- endif -%}

  {%- else -%}
    {%- if judge_shop.featured_carousel != blank -%}
      <div class="suds-jdgm-widget suds-jdgm-widget--carousel">
        {%- if review_subheading != blank -%}
          <div class="suds-jdgm-widget__head suds-jdgm-widget__head--compact">
            <p>{{ review_subheading }}</p>
          </div>
        {%- endif -%}
        <div class="suds-jdgm-widget__body">
          <div class="jdgm-carousel-wrapper">
            <div class="jdgm-carousel-title-and-link">
              <h3 class="jdgm-carousel-title">{{ review_heading | default: 'Let customers speak for us' }}</h3>
              {%- if judge_shop.all_reviews_rating != blank or judge_shop.all_reviews_count != blank -%}
                <a class="jdgm-all-reviews-rating-wrapper" href="/pages/reviews">
                  {%- if judge_shop.all_reviews_rating != blank -%}
                    <span
                      style="display:block"
                      data-score="{{ judge_shop.all_reviews_rating }}"
                      class="jdgm-all-reviews-rating"
                      aria-label="{{ judge_shop.all_reviews_rating }} stars"
                      tabindex="0"
                      role="img"
                    ></span>
                  {%- endif -%}
                  {%- if judge_shop.all_reviews_count != blank -%}
                    <span
                      style="display: block"
                      class="jdgm-carousel-number-of-reviews"
                      data-number-of-reviews="{{ judge_shop.all_reviews_count }}"
                    >
                      from {{ judge_shop.all_reviews_count }} reviews
                    </span>
                  {%- endif -%}
                </a>
              {%- endif -%}
            </div>
            {{ judge_shop.featured_carousel }}
          </div>
        </div>
      </div>
    {%- else -%}
      {%- liquid
        assign has_legacy_reviews = false
        if judge_shop.all_reviews_header != blank
          assign has_legacy_reviews = true
        endif
        assign has_v2025_reviews = false
        if judge_shop.all_reviews_widget_v2025_data != blank
          assign has_v2025_reviews = true
        endif
      -%}
      {%- if has_legacy_reviews or has_v2025_reviews -%}
        <div class="suds-jdgm-widget suds-jdgm-widget--all-reviews suds-jdgm-widget--compact-reviews">
          {%- if review_heading != blank or review_subheading != blank -%}
            <div class="suds-jdgm-widget__head">
              {%- if review_heading != blank -%}<h3>{{ review_heading }}</h3>{%- endif -%}
              {%- if review_subheading != blank -%}<p>{{ review_subheading }}</p>{%- endif -%}
            </div>
          {%- endif -%}
          <div
            class="jdgm-widget jdgm-all-reviews-widget-v2025"
            data-widget="all-reviews-v2025"
            data-auto-install="false"
            data-entry-point="all_reviews_widget_v2025.js"
            data-entry-key="all-reviews-widget-v2025/main.js"
          >
            {%- if has_legacy_reviews -%}
              <div class="jdgm-legacy-widget-content" style="display: none;">
                <article class="jdgm-widget jdgm-all-reviews-widget">
                  <style class="jdgm-temp-hiding-style">.jdgm-all-reviews-widget { display: none; }</style>
                  {{ judge_shop.all_reviews_header }}
                  <div class="jdgm-all-reviews__body">
                    {%- for i in (0..65535) -%}
                      {%- assign review_key = 'all_reviews_' | append: i -%}
                      {%- assign review_markup = judge_shop[review_key] -%}
                      {%- if review_markup == blank -%}
                        {%- break -%}
                      {%- endif -%}
                      {{ review_markup }}
                    {%- endfor -%}
                  </div>
                </article>
              </div>
            {%- endif -%}
          </div>
          {%- if has_v2025_reviews -%}
            <script>
              window.jdgm = window.jdgm || {};
              window.jdgm.data = window.jdgm.data || {};
              window.jdgm.data.allReviewsWidgetV2025 = {{ judge_shop.all_reviews_widget_v2025_data }};
            </script>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
{%- endcase -%}
