{%- liquid
  assign visual_variant = variant | default: 'signature'
  assign visual_mode = mode | default: 'card'
  assign visual_label = label | default: 'Suds Auto Salon generated mobile detailing visual'
-%}

<div class="suds-generated-visual suds-generated-visual--{{ visual_variant }} suds-generated-visual--{{ visual_mode }}" role="img" aria-label="{{ visual_label | escape }}">
  <span class="suds-generated-visual__sky"></span>
  <span class="suds-generated-visual__floor"></span>
  <span class="suds-generated-visual__glow suds-generated-visual__glow--one"></span>
  <span class="suds-generated-visual__glow suds-generated-visual__glow--two"></span>
  <span class="suds-generated-visual__car-shadow"></span>
  <span class="suds-generated-visual__car">
    <span class="suds-generated-visual__roof"></span>
    <span class="suds-generated-visual__window suds-generated-visual__window--front"></span>
    <span class="suds-generated-visual__window suds-generated-visual__window--rear"></span>
    <span class="suds-generated-visual__headlight"></span>
    <span class="suds-generated-visual__taillight"></span>
  </span>
  <span class="suds-generated-visual__wheel suds-generated-visual__wheel--front"></span>
  <span class="suds-generated-visual__wheel suds-generated-visual__wheel--rear"></span>
  <span class="suds-generated-visual__foam suds-generated-visual__foam--one"></span>
  <span class="suds-generated-visual__foam suds-generated-visual__foam--two"></span>
  <span class="suds-generated-visual__foam suds-generated-visual__foam--three"></span>
  <span class="suds-generated-visual__spray"></span>
  <span class="suds-generated-visual__wipe"></span>
  <span class="suds-generated-visual__buffer"></span>
  <span class="suds-generated-visual__bottle"></span>
  <span class="suds-generated-visual__worker suds-generated-visual__worker--left">
    <span class="suds-generated-visual__worker-head"></span>
    <span class="suds-generated-visual__worker-arm"></span>
    <span class="suds-generated-visual__worker-cloth"></span>
  </span>
  <span class="suds-generated-visual__worker suds-generated-visual__worker--right">
    <span class="suds-generated-visual__worker-head"></span>
    <span class="suds-generated-visual__worker-arm"></span>
    <span class="suds-generated-visual__worker-cloth"></span>
  </span>
</div>
