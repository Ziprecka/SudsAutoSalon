{%- liquid
  assign handle = page.handle | default: template.name
  assign eyebrow = 'Premium mobile detailing'
  assign h1 = page.title | default: 'Premium Mobile Auto Detailing'
  assign subheadline = 'Private mobile detailing at your home or office, matched to your vehicle condition and goals.'
  assign primary_label = 'Book Your Mobile Detail'
  assign primary_url = '/collections/mobile-details'
  assign secondary_label = 'Request a Quote'
  assign secondary_url = '/pages/contact-us'
  assign text_label = 'Send Photos if You Need a Recommendation'
  assign text_url = 'sms:+14253618838'

  case handle
    when 'basic-detail'
      assign eyebrow = 'Basic Detail'
      assign h1 = 'Basic Mobile Detail in Seattle'
      assign subheadline = 'A lighter mobile detail for vehicles that already stay fairly clean but need a professional interior and exterior refresh at your home or office.'
    when 'signature-detail'
      assign eyebrow = 'Signature Detail'
      assign h1 = 'Signature Mobile Detail in Seattle'
      assign subheadline = 'The best first booking for most daily drivers who want a proper interior and exterior reset without wasting time at a shop.'
    when 'elite-detail', 'elite-reset'
      assign eyebrow = 'Elite Detail'
      assign h1 = 'Elite Mobile Detail in Seattle'
      assign subheadline = 'Seattle mobile detailing for vehicles with heavier buildup, rougher exterior feel, pet use, family mess, or resale prep needs.'
    when 'ceramic-coating'
      assign eyebrow = 'Ceramic Coating'
      assign h1 = 'Ceramic Coating in Seattle'
      assign subheadline = 'Ceramic coating adds a durable layer of protection that helps your paint stay glossier, slicker, and easier to maintain after proper prep.'
    when 'paint-enhancement'
      assign eyebrow = 'Paint Enhancement'
      assign h1 = 'Paint Enhancement for Better Gloss and Finish'
      assign subheadline = 'A focused finish-improvement service for vehicles that need more clarity, shine, and paint preparation before protection.'
    when 'interior-detailing'
      assign eyebrow = 'Interior Detailing'
      assign h1 = 'Interior Car Detailing at Your Location'
      assign subheadline = 'Private mobile interior detailing for dust, grime, stains, pet hair, odor concerns, and daily-driver buildup.'
    when 'exterior-detailing'
      assign eyebrow = 'Exterior Detailing'
      assign h1 = 'Exterior Mobile Detailing and Protection'
      assign subheadline = 'A cleaner exterior, sharper wheels, better glass, dressed trim, and protection options for Seattle-area drivers.'
    when 'pet-hair-removal'
      assign eyebrow = 'Pet Hair Removal'
      assign h1 = 'Pet Hair Removal for Vehicle Interiors'
      assign subheadline = 'Targeted mobile detailing for pet hair, fur buildup, cargo areas, seats, carpets, and family vehicles.'
    when 'odor-treatment'
      assign eyebrow = 'Odor Treatment'
      assign h1 = 'Vehicle Odor Treatment and Interior Refresh'
      assign subheadline = 'Interior-focused service for odor concerns, spills, smoke smell, pet smells, and stale cabin buildup.'
    when 'maintenance-detailing'
      assign eyebrow = 'Maintenance Detailing'
      assign h1 = 'Monthly Maintenance Detailing'
      assign subheadline = 'Recurring mobile detailing that keeps your vehicle clean after the first reset instead of letting buildup return.'
    when 'services'
      assign eyebrow = 'Suds Auto Salon services'
      assign h1 = 'Mobile Detailing Services Built Around Vehicle Condition'
      assign subheadline = 'Choose Basic for upkeep, Signature for most first bookings, Elite for heavier condition, and protection services when the finish matters.'
    when 'faq'
      assign eyebrow = 'FAQ'
      assign h1 = 'Mobile Detailing Questions, Answered'
      assign subheadline = 'Direct answers about packages, pricing, photos, timing, service areas, pet hair, stains, ceramic coating, and booking.'
    when 'reviews'
      assign eyebrow = 'Reviews'
      assign h1 = 'Suds Auto Salon Reviews'
      assign subheadline = 'Real client feedback matters. Review the service, then book the mobile detail that fits your vehicle.'
    when 'about', 'about-us'
      assign eyebrow = 'About Suds Auto Salon'
      assign h1 = 'A Private Mobile Detailer for Seattle-Area Drivers'
      assign subheadline = 'Suds Auto Salon is owner-operated for customers who want direct communication, careful work, and mobile service without a shop drop-off.'
    when 'service-areas'
      assign eyebrow = 'Service areas'
      assign h1 = 'Mobile Detailing Service Areas'
      assign subheadline = 'Suds Auto Salon serves Seattle, Bellevue, Edmonds, Lynnwood, Everett, Marysville, Lake Stevens, Snohomish, and nearby PNW areas when route timing and access work.'
  endcase
-%}

<section class="suds-lp-hero">
  <div class="suds-lp-wrap suds-lp-hero__grid">
    <div>
      <p class="suds-lp-eyebrow">{{ eyebrow }}</p>
      <h1>{{ h1 }}</h1>
      <p class="suds-lp-lead">{{ subheadline }}</p>
      <div class="suds-lp-actions">
        <a class="suds-lp-button suds-lp-button--primary" href="{{ primary_url }}">{{ primary_label }}</a>
        <a class="suds-lp-button suds-lp-button--secondary" href="{{ secondary_url }}">{{ secondary_label }}</a>
        <a class="suds-lp-textlink" href="{{ text_url }}">{{ text_label }}</a>
      </div>
    </div>
    <aside class="suds-lp-proof" aria-label="Suds Auto Salon benefits">
      <strong>Private mobile detailer</strong>
      <span>Home or office appointments</span>
      <span>Packages matched to condition</span>
      <span>Seattle, Eastside, and North Sound routes</span>
    </aside>
  </div>
</section>

<style>
  .suds-lp-hero { background: #080808; color: #fff; }
  .suds-lp-wrap { max-width: 1180px; margin: 0 auto; padding: 64px 20px; }
  .suds-lp-hero__grid { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(280px, .8fr); gap: 32px; align-items: center; }
  .suds-lp-eyebrow { margin: 0 0 12px; color: #f2d36b; font-size: 1.3rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0; }
  .suds-lp-hero h1 { max-width: 900px; margin: 0; font-size: clamp(3.8rem, 7vw, 7rem); line-height: .96; letter-spacing: 0; }
  .suds-lp-hero h1 {
    text-wrap: balance;
  }
  .suds-lp-lead { max-width: 780px; margin: 20px 0 0; color: #f0f0f0; font-size: 1.8rem; line-height: 1.55; }
  .suds-lp-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-top: 28px; }
  .suds-lp-button { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 13px 20px; border-radius: 4px; font-weight: 800; text-decoration: none; }
  .suds-lp-button--primary { background: #f2d36b; color: #080808; border: 1px solid #f2d36b; }
  .suds-lp-button--secondary { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,.55); }
  .suds-lp-textlink { color: #f2d36b; font-weight: 800; text-underline-offset: 4px; }
  .suds-lp-proof { display: grid; gap: 12px; padding: 24px; border: 1px solid rgba(242,211,107,.48); border-radius: 8px; background: #15130d; }
  .suds-lp-proof strong { font-size: 2rem; }
  .suds-lp-proof span { padding-top: 12px; border-top: 1px solid rgba(255,255,255,.13); color: #eee; font-size: 1.5rem; }
  @media screen and (max-width: 820px) {
    .suds-lp-wrap { padding: 46px 18px; }
    .suds-lp-hero__grid { grid-template-columns: 1fr; }
    .suds-lp-actions { align-items: stretch; flex-direction: column; }
    .suds-lp-button, .suds-lp-textlink { width: 100%; text-align: center; }
  }
</style>

{% schema %}
{ "name": "Section hero service", "settings": [], "presets": [{ "name": "Section hero service" }] }
{% endschema %}
