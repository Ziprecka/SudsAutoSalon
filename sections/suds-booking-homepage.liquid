<script>
  (() => {
    const tabGroups = document.querySelectorAll('[data-suds-package-tabs]');

    tabGroups.forEach((group) => {
      const buttons = Array.from(group.querySelectorAll('[data-package-tab]'));
      const panels = Array.from(group.querySelectorAll('[data-package-panel]'));

      buttons.forEach((button, index) => {
        button.addEventListener('click', () => {
          const target = button.dataset.packageTab;
          group.style.setProperty('--suds-tab-index', index);

          buttons.forEach((item) => {
            const isSelected = item === button;
            item.classList.toggle('is-active', isSelected);
            item.setAttribute('aria-selected', String(isSelected));
          });

          panels.forEach((panel) => {
            const isActive = panel.dataset.packagePanel === target;
            panel.hidden = !isActive;
            panel.classList.toggle('is-active', isActive);
          });
        });
      });
    });
  })();
</script>

