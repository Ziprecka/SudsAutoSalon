{%- liquid
  assign basic_product = all_products['basic-detail']
  assign signature_product = all_products['signature-detail']
  assign elite_product = all_products['elite-detail']

  assign basic_url = '/products/basic-detail'
  if basic_product != blank
    assign basic_url = basic_product.url
  endif

  assign signature_url = '/products/signature-detail'
  if signature_product != blank
    assign signature_url = signature_product.url
  endif

  assign elite_url = '/products/elite-detail'
  if elite_product != blank
    assign elite_url = elite_product.url
  endif

  assign ceramic_url = '/pages/ceramic-coating'
  assign maintenance_url = '/pages/monthly-maintenance-plan'
  assign booking_url = signature_url
  assign quote_url = '/pages/contact-us'

  assign stock_hero_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_c2f80beb-6530-4420-8472-a92faccbe0f9.jpg?v=1779266080'
  assign stock_basic_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6648c2c3-acdf-423f-b835-b6e7f93d2e14.jpg?v=1779266055'
  assign stock_signature_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6ecb2b24-4ebc-4baa-872d-352805ac81a7.jpg?v=1779266049'
  assign stock_elite_image = 'https://images.pexels.com/photos/5233258/pexels-photo-5233258.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign stock_coating_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download.jpg?v=1779266040'
  assign stock_vehicle_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_b52468ed-4ba5-4ee9-94ba-541c2b16683b.jpg?v=1779266082'
  assign stock_interior_alt_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_fcc641e4-314c-48e8-ad61-9ecdacfcecd9.jpg?v=1779266078'
  assign stock_cabin_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_ad58bc49-9ae2-42c1-8558-4cf7ea1be591.jpg?v=1779266059'
  assign stock_dashboard_detail_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6ecb2b24-4ebc-4baa-872d-352805ac81a7.jpg?v=1779266049'
  assign stock_polish_image = 'https://images.pexels.com/photos/5233259/pexels-photo-5233259.jpeg?auto=compress&cs=tinysrgb&w=2200'

  assign hero_image = section.settings.hero_image
  if hero_image == blank and settings.brand_image != blank
    assign hero_image = settings.brand_image
  elsif hero_image == blank and signature_product.featured_image != blank
    assign hero_image = signature_product.featured_image
  elsif hero_image == blank and elite_product.featured_image != blank
    assign hero_image = elite_product.featured_image
  elsif hero_image == blank and basic_product.featured_image != blank
    assign hero_image = basic_product.featured_image
  endif

  assign basic_image = basic_product.featured_image
  if basic_image == blank
    assign basic_image = hero_image
  endif

  assign signature_image = signature_product.featured_image
  if signature_image == blank
    assign signature_image = hero_image
  endif

  assign elite_image = elite_product.featured_image
  if elite_image == blank
    assign elite_image = hero_image
  endif

  assign ceramic_image = hero_image
  if elite_product.featured_image != blank
    assign ceramic_image = elite_product.featured_image
  endif

  assign has_gallery_blocks = false
  assign has_app_block = false
  for block in section.blocks
    if block.type == 'gallery_image' and block.settings.image != blank
      assign has_gallery_blocks = true
    elsif block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{{ 'section-suds-booking-homepage.css' | asset_url | stylesheet_tag }}

<main class="suds-booking-home">
  <section class="suds-home-hero" id="top">
    <div class="suds-home-hero__image" aria-hidden="true">
      {%- if hero_image != blank -%}
        {{
          hero_image
          | image_url: width: 2200
          | image_tag:
            loading: 'eager',
            widths: '900, 1400, 1800, 2200',
            sizes: '100vw',
            alt: ''
        }}
      {%- else -%}
        <img src="{{ stock_hero_image }}" alt="" loading="eager">
      {%- endif -%}
    </div>

    <div class="suds-home-shell suds-home-hero__content">
      <p class="suds-home-hero__eyebrow">Seattle Mobile Detailing</p>
      <div class="suds-home-review-pill">
        <strong>5-star Google reviews</strong>
      </div>
      <h1>Seattle's Private Mobile Car Detail &mdash; At Your Driveway, Done Right.</h1>
      <p>
        Interior resets, ceramic coating, pet hair, and odor support handled by Sam, owner-operator. Serving Seattle, Bellevue, Edmonds, Lynnwood, Everett, and the Eastside.
      </p>
      <div class="suds-home-actions suds-home-actions--center">
        <a class="suds-home-button suds-home-button--gold" href="{{ booking_url }}">Book My Detail &rarr;</a>
        <a class="suds-home-button suds-home-button--black" href="{{ quote_url }}">Request a Quote</a>
      </div>
      <a class="suds-home-hero__hint" href="sms:+14253618838">Text photos to (425) 361-8838 for a quote if you want help choosing.</a>

      <div class="suds-home-trust-pills" aria-label="Suds Auto Salon trust signals">
        <span>Licensed WA LLC</span>
        <span>Private mobile detailer</span>
        <span>Seattle-area service</span>
        <span>At your home or office</span>
        <span>Interior + exterior packages</span>
      </div>
    </div>
  </section>

  <section class="suds-home-proof-strip" aria-label="Suds Auto Salon customer proof">
    <div class="suds-home-shell">
      <article>
        <p>"He came to my house with all that he needed. Highly recommend Sam and Suds Auto Salon."</p>
      </article>
      <article>
        <p>"He got old stains out of the seats and thoroughly cleaned every nook and cranny."</p>
      </article>
      <article>
        <p>"My car interior was done with great detail, it looks better than when I got it at the dealer."</p>
      </article>
    </div>
  </section>

  <section class="suds-home-packages" id="packages">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>Pick Your Package</h2>
        <p>Clear starting prices, fewer choices, and a simple path: choose the package that matches the condition of your vehicle.</p>
      </div>

      <div class="suds-home-ladder">
        <article class="suds-home-ladder-card">
          <div class="suds-home-ladder-card__image">
            <img src="{{ stock_basic_image }}" loading="lazy" alt="Interior vacuum detail work for Basic Detail upkeep">
          </div>
          <div class="suds-home-ladder-card__body">
            <p>Already maintained</p>
            <h3>Basic Detail</h3>
            {%- if basic_product != blank -%}<strong>Starting at {{ basic_product.price | money_without_trailing_zeros }}</strong>{%- endif -%}
            <span>Best for cleaner vehicles that need light upkeep, not heavy correction.</span>
            <ul>
              <li>Vacuum, wipe-down, glass</li>
              <li>Hand wash, tires, exterior glass</li>
              <li>Approx. 2 hours depending on size</li>
            </ul>
            <a href="{{ basic_url }}">Book Basic Detail</a>
          </div>
        </article>

        <article class="suds-home-ladder-card suds-home-ladder-card--featured">
          <div class="suds-home-ladder-card__image">
            <img src="{{ stock_signature_image }}" loading="lazy" alt="Interior console brush cleaning during Signature Detail service">
          </div>
          <div class="suds-home-ladder-card__body">
            <p>Most booked</p>
            <h3>Signature Detail</h3>
            {%- if signature_product != blank -%}<strong>Starting at {{ signature_product.price | money_without_trailing_zeros }}</strong>{%- endif -%}
            <span>The best first booking for most daily drivers with normal grime and buildup.</span>
            <ul>
              <li>Deeper interior reset and touchpoints</li>
              <li>Hand wash, wheels, trim, finish care</li>
              <li>Approx. 3-5 hours depending on condition</li>
            </ul>
            <a href="{{ signature_url }}">Book Signature</a>
          </div>
