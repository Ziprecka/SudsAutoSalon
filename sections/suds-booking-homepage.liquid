{%- liquid
  assign basic_product = all_products['basic-detail']
  assign signature_product = all_products['signature-detail']
  assign elite_product = all_products['elite-detail']

  assign basic_url = '/products/basic-detail'
  if basic_product != blank
    assign basic_url = basic_product.url
  endif

  assign signature_url = '/products/signature-detail'
  if signature_product != blank
    assign signature_url = signature_product.url
  endif

  assign elite_url = '/products/elite-detail'
  if elite_product != blank
    assign elite_url = elite_product.url
  endif

  assign ceramic_url = '/pages/ceramic-coating'
  assign maintenance_url = '/pages/maintenance-detailing'
  assign booking_url = '/collections/mobile-details'
  assign quote_url = '/pages/contact-us'

  assign stock_hero_image = 'https://images.pexels.com/photos/4870727/pexels-photo-4870727.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign stock_basic_image = 'https://images.pexels.com/photos/5288711/pexels-photo-5288711.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_signature_image = 'https://images.pexels.com/photos/4870727/pexels-photo-4870727.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_elite_image = 'https://images.pexels.com/photos/6873087/pexels-photo-6873087.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_coating_image = 'https://images.pexels.com/photos/30674510/pexels-photo-30674510.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_vehicle_image = 'https://images.pexels.com/photos/15822324/pexels-photo-15822324.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_interior_alt_image = 'https://images.pexels.com/photos/5288707/pexels-photo-5288707.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_cabin_image = 'https://images.pexels.com/photos/9138382/pexels-photo-9138382.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_dashboard_detail_image = 'https://images.pexels.com/photos/18471360/pexels-photo-18471360.jpeg?auto=compress&cs=tinysrgb&w=1200'
  assign stock_polish_image = 'https://images.pexels.com/photos/5233259/pexels-photo-5233259.jpeg?auto=compress&cs=tinysrgb&w=1200'

  assign hero_image = section.settings.hero_image
  if hero_image == blank and settings.brand_image != blank
    assign hero_image = settings.brand_image
  elsif hero_image == blank and signature_product.featured_image != blank
    assign hero_image = signature_product.featured_image
  elsif hero_image == blank and elite_product.featured_image != blank
    assign hero_image = elite_product.featured_image
  elsif hero_image == blank and basic_product.featured_image != blank
    assign hero_image = basic_product.featured_image
  endif

  assign basic_image = basic_product.featured_image
  if basic_image == blank
    assign basic_image = hero_image
  endif

  assign signature_image = signature_product.featured_image
  if signature_image == blank
    assign signature_image = hero_image
  endif

  assign elite_image = elite_product.featured_image
  if elite_image == blank
    assign elite_image = hero_image
  endif

  assign ceramic_image = hero_image
  if elite_product.featured_image != blank
    assign ceramic_image = elite_product.featured_image
  endif

  assign has_gallery_blocks = false
  assign has_app_block = false
  for block in section.blocks
    if block.type == 'gallery_image' and block.settings.image != blank
      assign has_gallery_blocks = true
    elsif block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{{ 'section-suds-booking-homepage.css' | asset_url | stylesheet_tag }}

<main class="suds-booking-home">
  <section class="suds-home-hero" id="top">
    <div class="suds-home-hero__image" aria-hidden="true">
      {%- if hero_image != blank -%}
        {{
          hero_image
          | image_url: width: 2200
          | image_tag:
            loading: 'eager',
            widths: '900, 1400, 1800, 2200',
            sizes: '100vw',
            alt: ''
        }}
      {%- else -%}
        <img src="{{ stock_hero_image }}" alt="" loading="eager">
      {%- endif -%}
    </div>

    <div class="suds-home-shell suds-home-hero__content">
      <div class="suds-home-review-pill">
        <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>Trusted by Seattle-area drivers</strong>
      </div>
      <h1><span>Premium Mobile</span> <span>Detailing</span> <span>in Seattle</span></h1>
      <p>
        Suds Auto Salon brings private interior and exterior detailing to your home or office. Choose the package that matches your vehicle's condition, then Suds handles the reset on site.
      </p>
      <div class="suds-home-actions suds-home-actions--center">
        <a class="suds-home-button suds-home-button--gold" href="{{ booking_url }}">Schedule Your Detail</a>
        <a class="suds-home-button suds-home-button--black" href="#packages">Compare Packages</a>
      </div>
      <a class="suds-home-hero__hint" href="{{ quote_url }}">Not sure what your vehicle needs? Ask for help choosing.</a>
    </div>
  </section>

  <section class="suds-home-services" id="services">
