                  {%- endif -%}
                </figure>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <p class="suds-home-results-note">Swipe or scroll to see more recent Suds details.</p>
        {%- else -%}
          <div class="suds-home-proof-empty">
            <p>More approved Suds work photos can be added here as new details are photographed.</p>
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  <section class="suds-home-final">
