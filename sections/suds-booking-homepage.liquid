{%- liquid
  assign basic_product = all_products['basic-detail']
  assign signature_product = all_products['signature-detail']
  assign elite_product = all_products['elite-detail']

  assign basic_url = '/products/basic-detail'
  if basic_product != blank
    assign basic_url = basic_product.url
  endif

  assign signature_url = '/products/signature-detail'
  if signature_product != blank
    assign signature_url = signature_product.url
  endif

  assign elite_url = '/products/elite-detail'
  if elite_product != blank
    assign elite_url = elite_product.url
  endif

  assign ceramic_url = '/pages/ceramic-coating'
  assign maintenance_url = '/pages/maintenance-detailing'
  assign booking_url = '/collections/mobile-details'
  assign quote_url = '/pages/contact-us'

  assign stock_hero_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_c2f80beb-6530-4420-8472-a92faccbe0f9.jpg?v=1779266080'
  assign stock_basic_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6648c2c3-acdf-423f-b835-b6e7f93d2e14.jpg?v=1779266055'
  assign stock_signature_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6ecb2b24-4ebc-4baa-872d-352805ac81a7.jpg?v=1779266049'
  assign stock_elite_image = 'https://images.pexels.com/photos/5233258/pexels-photo-5233258.jpeg?auto=compress&cs=tinysrgb&w=2200'
  assign stock_coating_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download.jpg?v=1779266040'
  assign stock_vehicle_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_b52468ed-4ba5-4ee9-94ba-541c2b16683b.jpg?v=1779266082'
  assign stock_interior_alt_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_fcc641e4-314c-48e8-ad61-9ecdacfcecd9.jpg?v=1779266078'
  assign stock_cabin_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_ad58bc49-9ae2-42c1-8558-4cf7ea1be591.jpg?v=1779266059'
  assign stock_dashboard_detail_image = 'https://cdn.shopify.com/s/files/1/0755/7713/1295/files/download_6ecb2b24-4ebc-4baa-872d-352805ac81a7.jpg?v=1779266049'
  assign stock_polish_image = 'https://images.pexels.com/photos/5233259/pexels-photo-5233259.jpeg?auto=compress&cs=tinysrgb&w=2200'

  assign hero_image = section.settings.hero_image
  if hero_image == blank and settings.brand_image != blank
    assign hero_image = settings.brand_image
  elsif hero_image == blank and signature_product.featured_image != blank
    assign hero_image = signature_product.featured_image
  elsif hero_image == blank and elite_product.featured_image != blank
    assign hero_image = elite_product.featured_image
  elsif hero_image == blank and basic_product.featured_image != blank
    assign hero_image = basic_product.featured_image
  endif

  assign basic_image = basic_product.featured_image
  if basic_image == blank
    assign basic_image = hero_image
  endif

  assign signature_image = signature_product.featured_image
  if signature_image == blank
    assign signature_image = hero_image
  endif

  assign elite_image = elite_product.featured_image
  if elite_image == blank
    assign elite_image = hero_image
  endif

  assign ceramic_image = hero_image
  if elite_product.featured_image != blank
    assign ceramic_image = elite_product.featured_image
  endif

  assign has_gallery_blocks = false
  assign has_app_block = false
  for block in section.blocks
    if block.type == 'gallery_image' and block.settings.image != blank
      assign has_gallery_blocks = true
    elsif block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{{ 'section-suds-booking-homepage.css' | asset_url | stylesheet_tag }}

<main class="suds-booking-home">
  <section class="suds-home-hero" id="top">
    <div class="suds-home-hero__image" aria-hidden="true">
      {%- if hero_image != blank -%}
        {{
          hero_image
          | image_url: width: 2200
          | image_tag:
            loading: 'eager',
            widths: '900, 1400, 1800, 2200',
            sizes: '100vw',
            alt: ''
        }}
      {%- else -%}
        <img src="{{ stock_hero_image }}" alt="" loading="eager">
      {%- endif -%}
    </div>

    <div class="suds-home-shell suds-home-hero__content">
      <p class="suds-home-hero__eyebrow">Seattle Mobile Detailing</p>
      <div class="suds-home-review-pill">
        <strong>Review-backed local business</strong>
      </div>
      <h1>Private Mobile Detailing for Seattle Drivers Who Want Their Car Reset Properly</h1>
      <p>
        Suds Auto Salon brings appointment-based interior and exterior detailing to your home or office &mdash; built for daily-driver buildup, cleaner cabins, sharper finishes, and a simpler way to care for your vehicle.
      </p>
      <div class="suds-home-actions suds-home-actions--center">
        <a class="suds-home-button suds-home-button--gold" href="{{ quote_url }}">Request a Quote</a>
        <a class="suds-home-button suds-home-button--black" href="{{ booking_url }}">Book Your Mobile Detail</a>
      </div>
      <a class="suds-home-hero__hint" href="{{ quote_url }}">Not sure what to book? Send photos and Sam will recommend the right package.</a>

      <div class="suds-home-trust-pills" aria-label="Suds Auto Salon trust signals">
        <span>Private mobile detailer</span>
        <span>Seattle-area service</span>
        <span>At your home or office</span>
        <span>Review-backed local business</span>
        <span>Interior + exterior packages</span>
      </div>
    </div>
  </section>

  <section class="suds-home-proof-strip" aria-label="Suds Auto Salon customer proof">
    <div class="suds-home-shell">
      <article>
        <p>"He came to my house with all that he needed. Highly recommend Sam and Suds Auto Salon."</p>
      </article>
      <article>
        <p>"He got old stains out of the seats and thoroughly cleaned every nook and cranny."</p>
      </article>
      <article>
        <p>"My car interior was done with great detail, it looks better than when I got it at the dealer."</p>
      </article>
    </div>
  </section>

  <section class="suds-home-packages" id="packages">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>Choose the Detail That Fits Your Vehicle</h2>
        <p>Every vehicle comes in with a different level of buildup. Start with the package that matches your condition, or send photos for a recommendation.</p>
      </div>

      <div class="suds-home-ladder">
        <article class="suds-home-ladder-card">
          <div class="suds-home-ladder-card__image">
            <img src="{{ stock_basic_image }}" loading="lazy" alt="Interior vacuum detail work for Basic Detail upkeep">
          </div>
          <div class="suds-home-ladder-card__body">
            <p>Clean upkeep for maintained vehicles.</p>
            <h3>Basic Detail</h3>
            <span>Best for vehicles that already stay fairly clean and need a lighter interior and exterior refresh.</span>
            {%- if basic_product != blank -%}<strong>From {{ basic_product.price | money_without_trailing_zeros }}</strong>{%- endif -%}
            <a href="{{ basic_url }}">View Basic Detail</a>
          </div>
        </article>

        <article class="suds-home-ladder-card suds-home-ladder-card--featured">
          <div class="suds-home-ladder-card__image">
            <img src="{{ stock_signature_image }}" loading="lazy" alt="Interior console brush cleaning during Signature Detail service">
          </div>
          <div class="suds-home-ladder-card__body">
            <p>The best first booking for most daily drivers.</p>
            <h3>Signature Detail</h3>
            <span>Best for vehicles that need a proper inside-and-out reset without jumping into heavy restoration.</span>
            {%- if signature_product != blank -%}<strong>From {{ signature_product.price | money_without_trailing_zeros }}</strong>{%- endif -%}
            <a href="{{ signature_url }}">View Signature Detail</a>
          </div>
        </article>

        <article class="suds-home-ladder-card">
          <div class="suds-home-ladder-card__image">
            <img src="{{ stock_elite_image }}" loading="lazy" alt="Machine polishing black paint during Elite Detail mobile detailing">
          </div>
          <div class="suds-home-ladder-card__body">
            <p>A premium reset for heavier buildup.</p>
            <h3>Elite Detail</h3>
            <span>Best for vehicles with more interior grime, rougher exterior feel, pet mess, family use, or resale prep needs.</span>
            {%- if elite_product != blank -%}<strong>From {{ elite_product.price | money_without_trailing_zeros }}</strong>{%- endif -%}
            <a href="{{ elite_url }}">View Elite Detail</a>
          </div>
        </article>

        <article class="suds-home-ladder-card">
          <div class="suds-home-ladder-card__image">
            <img src="{{ stock_coating_image }}" loading="lazy" alt="Ceramic coating wipe-on application for longer paint protection">
          </div>
          <div class="suds-home-ladder-card__body">
            <p>Gloss and protection that lasts longer than wax.</p>
            <h3>Ceramic Coating</h3>
            <span>Best for drivers who want stronger paint protection, easier washing, and a deeper finish after proper prep.</span>
            <a href="{{ ceramic_url }}">View Ceramic Coating</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="suds-home-results" id="gallery">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>Real Results From Recent Details</h2>
        <p>See the kind of interior and exterior work Suds is built for &mdash; cleaner cabins, sharper finishes, and vehicles that feel cared for again.</p>
      </div>

      <div class="suds-home-results-grid" aria-label="Suds Auto Salon detailing result examples">
        {%- if has_gallery_blocks -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'gallery_image' and block.settings.image != blank -%}
              <figure class="suds-home-result-card" {{ block.shopify_attributes }}>
                {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(min-width: 990px) 33vw, 100vw', alt: block.settings.alt_text }}
                <figcaption>{{ block.settings.caption }}</figcaption>
              </figure>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <figure class="suds-home-result-card"><img src="{{ stock_signature_image }}" loading="lazy" alt="Interior console detailing during a daily-driver reset"><figcaption>Interior reset for daily-driver buildup</figcaption></figure>
          <figure class="suds-home-result-card"><img src="{{ stock_basic_image }}" loading="lazy" alt="Vacuum detail work removing daily debris from a vehicle cabin"><figcaption>Pet hair and interior cleanup</figcaption></figure>
          <figure class="suds-home-result-card"><img src="{{ stock_elite_image }}" loading="lazy" alt="Machine polishing black paint for exterior gloss improvement"><figcaption>Gloss and protection upgrade</figcaption></figure>
          <figure class="suds-home-result-card"><img src="{{ stock_vehicle_image }}" loading="lazy" alt="Wheel and tire cleanup on a black vehicle"><figcaption>Wheel and tire cleanup</figcaption></figure>
          <figure class="suds-home-result-card"><img src="{{ stock_interior_alt_image }}" loading="lazy" alt="Steam cleaning an interior door panel during a family vehicle detail"><figcaption>Family vehicle detail</figcaption></figure>
          <figure class="suds-home-result-card"><img src="{{ stock_polish_image }}" loading="lazy" alt="Paint polishing for exterior wash, clay, and wax finish work"><figcaption>Exterior wash, clay, and wax finish</figcaption></figure>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="suds-home-addons">
    <div class="suds-home-shell suds-home-addons__grid">
      <div>
        <div class="suds-home-section-title">
          <h2>Start With the Reset. Add Only What the Vehicle Actually Needs.</h2>
          <p>Some vehicles need more than a standard detail. Suds can recommend the right add-ons based on condition, goals, and photos.</p>
        </div>
        <div class="suds-home-addon-grid">
          <article><h3>Pet Hair Removal</h3><p>For vehicles with embedded pet hair in carpets, seats, or cargo areas.</p></article>
          <article><h3>Stain Extraction</h3><p>For upholstery and carpets with visible spills, marks, or built-up grime.</p></article>
          <article><h3>Odor Treatment</h3><p>For interiors that need extra help beyond normal cleaning.</p></article>
          <article><h3>Paint Enhancement</h3><p>For paint that looks dull and needs more gloss before protection.</p></article>
          <article><h3>Ceramic Protection</h3><p>For longer-lasting gloss, slickness, and easier maintenance.</p></article>
          <article><h3>Maintenance Plan</h3><p>For keeping the vehicle clean after the first reset.</p></article>
        </div>
      </div>

      <aside class="suds-home-value-path" aria-label="Best value Suds Auto Salon service path">
        <h3>Best-value path</h3>
        <ol>
          <li><strong>First:</strong> Signature Detail or Elite Detail</li>
          <li><strong>Then:</strong> Paint enhancement or ceramic protection</li>
          <li><strong>After:</strong> Monthly maintenance plan</li>
        </ol>
        <a class="suds-home-button suds-home-button--gold" href="{{ quote_url }}">Request a Quote</a>
      </aside>
    </div>
  </section>

  <section class="suds-home-process" id="process">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>How Suds Mobile Detailing Works</h2>
      </div>
      <div class="suds-home-process-grid">
        <article><span>01</span><h3>Send your vehicle details</h3><p>Share the vehicle, location, condition, and photos if possible.</p></article>
        <article><span>02</span><h3>Get the right recommendation</h3><p>Sam helps match your vehicle to the right detail or add-on.</p></article>
        <article><span>03</span><h3>Get service at your location</h3><p>Suds comes to your home, office, or approved service location.</p></article>
        <article><span>04</span><h3>Enjoy the reset</h3><p>Cleaner interior, sharper exterior, and a vehicle that feels easier to maintain.</p></article>
      </div>
    </div>
  </section>

  <section class="suds-home-reviews" id="reviews">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>Reviewed by Seattle-Area Drivers</h2>
        <p>Real customer excerpts from Suds Auto Salon reviews.</p>
      </div>
      <div class="suds-home-review-grid">
        <article><p>"He came to my house with all that he needed. Highly recommend Sam and Suds Auto Salon."</p></article>
        <article><p>"He got old stains out of the seats and thoroughly cleaned every nook and cranny."</p></article>
        <article><p>"My car interior was done with great detail, it looks better than when I got it at the dealer."</p></article>
      </div>
      {%- if has_app_block -%}
        <div class="suds-home-app-reviews">
          {%- for block in section.blocks -%}
            {%- if block.type == '@app' -%}
              {% render block %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="suds-home-app-reviews">
          <p>Customer reviews load below when a review app block is connected in Shopify. Suds Auto Salon is trusted by local drivers for private mobile detailing at home or office.</p>
        </div>
      {%- endif -%}
    </div>
  </section>

  <section class="suds-home-areas" id="areas">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>Mobile Detailing Across Seattle, the Eastside, and the North Sound</h2>
        <p>Suds Auto Salon provides appointment-based mobile detailing at homes, offices, apartments, and approved service locations across the Seattle area.</p>
      </div>
      <div class="suds-home-area-links">
        <a href="/pages/seattle-mobile-detailing">Seattle</a>
        <a href="/pages/bellevue-mobile-detailing">Bellevue</a>
        <a href="/pages/edmonds-mobile-detailing">Edmonds</a>
        <a href="/pages/lynnwood-mobile-detailing">Lynnwood</a>
        <a href="/pages/everett-mobile-detailing">Everett</a>
        <a href="/pages/marysville-mobile-detailing">Marysville</a>
        <a href="/pages/lake-stevens-mobile-detailing">Lake Stevens</a>
        <a href="/pages/snohomish-mobile-detailing">Snohomish</a>
        <a href="/pages/service-areas">Shoreline</a>
      </div>
    </div>
  </section>

  <section class="suds-home-faq-section" id="faq">
    <div class="suds-home-shell">
      <div class="suds-home-section-title suds-home-section-title--center">
        <h2>Questions Before You Book</h2>
      </div>
      <div class="suds-home-faq">
        <details><summary>Which detail should I book?</summary><p>If your vehicle is already maintained, Basic may be enough. If it needs a proper inside-and-out reset, start with Signature. If it has heavier buildup, pet mess, rough paint, or resale prep needs, Elite is usually the better fit.</p></details>
        <details><summary>Do you come to my home or office?</summary><p>Yes. Suds Auto Salon is mobile and details at homes, offices, apartments, and approved service locations when access and route timing work.</p></details>
        <details><summary>How much does mobile detailing cost?</summary><p>Pricing depends on the package, vehicle size, condition, and add-ons. The booking page shows package pricing, and a quote helps when the vehicle needs extra time or special treatment.</p></details>
        <details><summary>Do I need to send photos?</summary><p>No. You can book directly if you know the package. Photos are helpful when you are unsure, when the vehicle has pet hair, stains, odor, or when you want the most accurate recommendation.</p></details>
        <details><summary>How long does a detail take?</summary><p>Timing depends on vehicle size, condition, access, and add-ons. Basic is lighter, Signature is the best fit for most vehicles, and Elite reserves more time for heavier condition.</p></details>
        <details><summary>Do you clean pet hair?</summary><p>Yes. Pet hair can be cleaned, but heavy embedded hair may need extra time or a pet hair add-on so the appointment is set up correctly.</p></details>
        <details><summary>Do you remove stains?</summary><p>Spot treatment and extraction can improve many stains, but results depend on material, age, and severity. Severe or set-in stains should be quoted before the appointment.</p></details>
        <details><summary>Do you offer ceramic coating?</summary><p>Yes. Ceramic coating is available as a protection upgrade after the vehicle is cleaned and properly prepped. Paint condition determines the right prep path.</p></details>
        <details><summary>What areas do you serve?</summary><p>Suds serves Seattle, Bellevue, Edmonds, Lynnwood, Everett, Marysville, Lake Stevens, Snohomish, and nearby areas when scheduling and route timing work.</p></details>
        <details><summary>Is this a car wash or a full detail?</summary><p>This is mobile detailing, not a tunnel wash. Suds handles interior and exterior cleaning with package depth matched to the condition of the vehicle.</p></details>
      </div>
    </div>
  </section>

  <section class="suds-home-final">
    <div class="suds-home-shell">
      <h2>Ready for a Cleaner Vehicle Without the Shop Drop-Off?</h2>
      <p>Send your vehicle, city, and photos. Sam will recommend the right Suds package based on condition, goals, and the result you want.</p>
      <div class="suds-home-actions suds-home-actions--center">
        <a class="suds-home-button suds-home-button--gold" href="{{ quote_url }}">Request a Quote</a>
        <a class="suds-home-button suds-home-button--black" href="{{ booking_url }}">Book Your Mobile Detail</a>
      </div>
    </div>
  </section>
</main>

