{%- liquid
  assign handle = page.handle | default: 'seattle-mobile-detailing'
  assign city = page.title | remove: ' Mobile Detailing' | remove: 'Mobile Detailing ' | default: 'Seattle'
  assign intro = 'Suds Auto Salon provides private mobile detailing at homes, offices, and approved locations in this service area.'
  assign use_case = 'Busy drivers, families, commuters, pet owners, and professionals who want the vehicle handled without a shop drop-off.'

  case handle
    when 'seattle-mobile-detailing', 'mobile-detailing-seattle'
      assign city = 'Seattle'
      assign intro = 'Seattle drivers deal with rain, tight schedules, apartment parking, daily commuting, pet mess, and road film. Suds Auto Salon brings premium mobile detailing to your home, office, or approved location.'
      assign use_case = 'Best for city commuters, families, pet owners, condo and apartment residents, and professionals who want a clean car without losing time at a shop.'
    when 'bellevue-mobile-detailing', 'mobile-detailing-bellevue'
      assign city = 'Bellevue'
      assign intro = 'Bellevue customers often want a cleaner, sharper vehicle without interrupting work or family schedules. Suds Auto Salon provides private mobile detailing for daily drivers, luxury vehicles, and maintenance clients.'
      assign use_case = 'Best for luxury car owners, professionals, families, garage-kept vehicles, and drivers who care about presentation and protection.'
    when 'edmonds-mobile-detailing', 'mobile-detailing-edmonds'
      assign city = 'Edmonds'
      assign intro = 'Edmonds vehicles see coastal moisture, family use, commuting, and weekend travel. Suds Auto Salon brings mobile detailing to local homes and approved service locations.'
      assign use_case = 'Best for homeowners, commuters, family vehicles, pet owners, and customers who want a private detailer instead of a volume shop.'
    when 'lynnwood-mobile-detailing', 'mobile-detailing-lynnwood'
      assign city = 'Lynnwood'
      assign intro = 'Lynnwood is a strong fit for mobile detailing because many customers want convenience, route-friendly scheduling, and clean vehicles without driving across town.'
      assign use_case = 'Best for commuters, apartment residents, families, rideshare drivers, and recurring maintenance clients.'
    when 'everett-mobile-detailing', 'mobile-detailing-everett'
      assign city = 'Everett'
      assign intro = 'Everett drivers often need mobile details for daily-driver buildup, family SUVs, work vehicles, resale prep, and weather-exposed exteriors.'
      assign use_case = 'Best for family vehicles, commuter cars, work trucks, resale prep, pet vehicles, and monthly maintenance routes.'
    when 'marysville-mobile-detailing', 'mobile-detailing-marysville'
      assign city = 'Marysville'
      assign intro = 'Marysville mobile detailing is built around convenience, larger vehicles, family use, trucks, commuters, and route-based service without a shop visit.'
      assign use_case = 'Best for family SUVs, trucks, pet vehicles, commuters, and customers who want mobile upkeep after the first reset.'
    when 'lake-stevens-mobile-detailing', 'mobile-detailing-lake-stevens'
      assign city = 'Lake Stevens'
      assign intro = 'Lake Stevens vehicles often need help with family mess, outdoor use, pet hair, commuting, and seasonal road grime. Suds Auto Salon brings the detail to you.'
      assign use_case = 'Best for families, SUVs, trucks, lake-life vehicles, pet owners, and recurring maintenance clients.'
    when 'snohomish-mobile-detailing', 'mobile-detailing-snohomish'
      assign city = 'Snohomish'
      assign intro = 'Snohomish mobile detailing is ideal for drivers who want careful service at home, especially for trucks, family vehicles, pet vehicles, and rural-road buildup.'
      assign use_case = 'Best for trucks, family vehicles, pet owners, resale prep, and customers who want the convenience of a private mobile detailer.'
  endcase
-%}

<section class="suds-location">
  <div class="suds-location__wrap">
    <p class="suds-location__eyebrow">{{ city }} mobile detailing</p>
    <h1>Premium mobile detailing in {{ city }}.</h1>
    <p class="suds-location__lead">{{ intro }}</p>
    <div class="suds-lp-actions">
      <a class="suds-lp-button suds-lp-button--primary" href="/pages/contact-us">Request a Quote</a>
      <a class="suds-lp-button suds-lp-button--secondary" href="/collections/mobile-details">Book Your Mobile Detail</a>
      <a class="suds-location__text" href="sms:+14253618838">Text Photos for a Faster Quote</a>
    </div>
    <div class="suds-location__grid">
      <article><h2>Who it is for</h2><p>{{ use_case }}</p></article>
      <article><h2>Services offered</h2><p>Basic Detail, Signature Detail, Elite Reset, interior detailing, exterior detailing, pet hair removal, odor treatment, ceramic coating, paint enhancement, and maintenance detailing.</p></article>
      <article><h2>Common use cases</h2><p>Daily-driver buildup, family mess, pet hair, resale prep, lease return cleanup, road film, stale interiors, and vehicles that need a cleaner routine.</p></article>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Mobile Detailing in {{ city }}",
  "serviceType": "Mobile auto detailing",
  "provider": { "@id": "{{ shop.url }}/#suds-auto-salon" },
  "areaServed": "{{ city }}, WA",
  "url": "{{ canonical_url }}"
}
</script>

<style>
  .suds-location { background: #080808; color: #fff; }
  .suds-location__wrap { max-width: 1180px; margin: 0 auto; padding: 64px 20px; }
  .suds-location__eyebrow { margin: 0 0 12px; color: #f2d36b; font-size: 1.3rem; font-weight: 800; text-transform: uppercase; }
  .suds-location h1 { max-width: 920px; margin: 0; font-size: clamp(3.8rem, 7vw, 7rem); line-height: .96; letter-spacing: 0; }
  .suds-location__lead { max-width: 820px; margin: 20px 0 0; color: #f1f1f1; font-size: 1.8rem; line-height: 1.55; }
  .suds-location__text { color: #f2d36b; font-weight: 800; text-underline-offset: 4px; }
  .suds-location__grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 16px; margin-top: 34px; }
  .suds-location article { padding: 24px; border: 1px solid rgba(242,211,107,.32); border-radius: 8px; background: #141414; }
  .suds-location h2 { margin: 0 0 10px; letter-spacing: 0; }
  .suds-location p { color: #efefef; font-size: 1.55rem; line-height: 1.55; }
  @media screen and (max-width: 820px) { .suds-location__wrap { padding: 46px 18px; } .suds-location__grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{ "name": "Section location service area", "settings": [], "presets": [{ "name": "Section location service area" }] }
{% endschema %}
