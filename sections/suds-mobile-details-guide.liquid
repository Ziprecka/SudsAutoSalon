<section class="suds-mobile-details">
  <div class="suds-mobile-details__wrap">
    <div class="suds-mobile-details__hero">
      <div>
        <p class="suds-mobile-details__eyebrow">Mobile detailing packages</p>
        <h1>Text photos first. Book the right detail once.</h1>
        <p class="suds-mobile-details__lead">
          Vehicle condition changes the right service. Text Sam your vehicle, city, and a few photos before booking
          so Suds Auto Salon can match you with the correct package and recommend only the add-ons that make sense.
        </p>
        <div class="suds-mobile-details__actions">
          <a class="suds-mobile-details__button suds-mobile-details__button--primary" href="sms:+14253618838">Text Photos to Sam</a>
          <a class="suds-mobile-details__button suds-mobile-details__button--secondary" href="/pages/contact-us">Quote Instructions</a>
        </div>
      </div>

      <aside class="suds-mobile-details__quote-box">
        <p class="suds-mobile-details__eyebrow">Send this</p>
        <ul>
          <li>Year, make, and model</li>
          <li>Your city or neighborhood</li>
          <li>Interior photos</li>
          <li>Exterior photos</li>
          <li>Problem areas: pet hair, stains, odor, mold, paint, or heavy grime</li>
        </ul>
      </aside>
    </div>

    <div class="suds-mobile-details__chooser" aria-label="Package chooser">
      <article>
        <p class="suds-mobile-details__label">Light upkeep</p>
        <h2>Basic Detail</h2>
        <p>Choose this if the vehicle is already fairly clean and needs a professional maintenance refresh.</p>
      </article>
      <article class="suds-mobile-details__featured">
        <p class="suds-mobile-details__label">Best first booking</p>
        <h2>Signature Detail</h2>
        <p>Choose this for most vehicles that need a real inside-and-out reset without going into heavy restoration.</p>
      </article>
      <article>
        <p class="suds-mobile-details__label">Heavy condition</p>
        <h2>Elite Detail</h2>
        <p>Choose this for family SUVs, pet vehicles, neglected interiors, resale prep, and deeper transformation work.</p>
      </article>
    </div>
  </div>
</section>

<style>
  .suds-mobile-details {
    background: #ffffff;
    color: #111111;
  }

  .suds-mobile-details__wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 56px 20px 28px;
  }

  .suds-mobile-details__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, .8fr);
    gap: 28px;
    align-items: center;
  }

  .suds-mobile-details__eyebrow,
  .suds-mobile-details__label {
    margin: 0 0 12px;
    color: #8c6b05;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .suds-mobile-details h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(3.8rem, 7vw, 7rem);
    line-height: .95;
    letter-spacing: 0;
  }

  .suds-mobile-details h2 {
    margin: 0 0 10px;
    font-size: clamp(2.4rem, 3vw, 3.2rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .suds-mobile-details__lead,
  .suds-mobile-details p,
  .suds-mobile-details li {
    color: #292929;
    font-size: 1.65rem;
    line-height: 1.55;
  }

  .suds-mobile-details__lead {
    max-width: 760px;
    margin: 20px 0 0;
  }

  .suds-mobile-details__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .suds-mobile-details__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 13px 20px;
    border: 1px solid #111111;
    border-radius: 4px;
    font-weight: 800;
    text-decoration: none;
  }

  .suds-mobile-details__button--primary {
    background: #111111;
    color: #ffffff;
  }

  .suds-mobile-details__button--secondary {
    background: #ffffff;
    color: #111111;
  }

  .suds-mobile-details__quote-box,
  .suds-mobile-details__chooser article {
    border: 1px solid #dedede;
    border-radius: 8px;
    background: #f7f7f7;
    padding: 24px;
  }

  .suds-mobile-details__quote-box ul {
    margin: 0;
    padding-left: 20px;
  }

  .suds-mobile-details__chooser {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 34px;
  }

  .suds-mobile-details__chooser .suds-mobile-details__featured {
    border-color: #b9931b;
    background: #fffaf0;
  }

  .suds-mobile-details + .section .collection {
    padding-top: 12px;
  }

  .suds-mobile-details + .section .product-grid {
    row-gap: 28px;
  }

  .suds-mobile-details + .section .card-wrapper {
    height: 100%;
  }

  .suds-mobile-details + .section .card {
    border: 1px solid #e1e1e1;
    border-radius: 8px;
    box-shadow: 0 12px 30px rgba(17, 17, 17, .05);
    overflow: hidden;
  }

  .suds-mobile-details + .section .card__information {
    padding: 1.8rem;
  }

  .suds-mobile-details + .section .card__heading {
    font-size: 2rem;
    letter-spacing: 0;
  }

  .suds-mobile-details + .section .price {
    margin-top: .6rem;
    font-weight: 800;
  }

  @media screen and (max-width: 900px) {
    .suds-mobile-details__hero,
    .suds-mobile-details__chooser {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .suds-mobile-details__wrap {
      padding: 42px 18px 20px;
    }

    .suds-mobile-details__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .suds-mobile-details__button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Suds mobile details guide",
  "settings": [],
  "presets": [
    {
      "name": "Suds mobile details guide"
    }
  ]
}
{% endschema %}
