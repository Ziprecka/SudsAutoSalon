{%- liquid
  assign quote_url = '/pages/contact-us'
  assign booking_url = '/collections/mobile-details'
-%}

<section class="suds-maintenance">
  <div class="suds-maintenance__hero">
    <p>Monthly Maintenance Detailing</p>
    <h1>Keep the Vehicle Clean After the Reset</h1>
    <div>Maintenance plans are for drivers who already had the vehicle reset and want priority upkeep instead of paying for a heavy detail every few months.</div>
    <div class="suds-maintenance__actions">
      <a href="{{ quote_url }}">Ask About Maintenance</a>
      <a href="{{ booking_url }}">Book the First Reset</a>
    </div>
  </div>

  <div class="suds-maintenance__tiers">
    <article>
      <span>Refresh</span>
      <h2>$89/mo</h2>
      <p>Monthly exterior hand wash and light interior wipe-down for vehicles that already stay clean.</p>
      <ul>
        <li>Priority route consideration</li>
        <li>Exterior hand wash</li>
        <li>Interior touchpoint wipe-down</li>
        <li>Best after Basic or Signature</li>
      </ul>
      <a href="{{ quote_url }}">Start Refresh</a>
    </article>
    <article class="is-featured">
      <span>Maintain</span>
      <h2>$159/mo</h2>
      <p>The best fit for most maintenance clients who want consistent upkeep without letting buildup return.</p>
      <ul>
        <li>Everything in Refresh</li>
        <li>Bi-monthly interior reset rhythm</li>
        <li>Better for commuters and families</li>
        <li>Priority scheduling</li>
      </ul>
      <a href="{{ quote_url }}">Start Maintain</a>
    </article>
    <article>
      <span>Concierge</span>
      <h2>$279/mo</h2>
      <p>Premium upkeep for drivers who want the cleanest routine and first access to add-ons.</p>
      <ul>
        <li>Monthly Signature-style upkeep</li>
        <li>Priority scheduling</li>
        <li>10% off eligible add-ons</li>
        <li>Best for higher-value vehicles</li>
      </ul>
      <a href="{{ quote_url }}">Start Concierge</a>
    </article>
  </div>

  <div class="suds-maintenance__note">
    <h2>Start with the reset first.</h2>
    <p>Maintenance works best after Basic, Signature, or Elite has already brought the vehicle back to a clean baseline. If the vehicle has pet hair, stains, odor, or heavy buildup, book the reset first and then move into a plan.</p>
  </div>
</section>

<style>
  .suds-maintenance {
    background: #f8f7f2;
    color: #111111;
  }

  .suds-maintenance__hero,
  .suds-maintenance__tiers,
  .suds-maintenance__note {
    width: min(100% - 40px, 1160px);
    margin: 0 auto;
  }

  .suds-maintenance__hero {
    padding: clamp(64px, 8vw, 112px) 0 38px;
    text-align: center;
  }

  .suds-maintenance__hero > p,
  .suds-maintenance__tiers span {
    margin: 0 0 12px;
    color: #8c6b05;
    font-size: 1.2rem;
    font-weight: 950;
    letter-spacing: .06em;
    line-height: 1;
    text-transform: uppercase;
  }

  .suds-maintenance h1,
  .suds-maintenance h2 {
    margin: 0;
    letter-spacing: 0;
    line-height: .98;
  }

  .suds-maintenance h1 {
    max-width: 860px;
    margin: 0 auto;
    font-size: clamp(4rem, 6vw, 7rem);
  }

  .suds-maintenance__hero div {
    max-width: 740px;
    margin: 18px auto 0;
    color: #292929;
    font-size: 1.75rem;
    line-height: 1.55;
  }

  .suds-maintenance__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 28px !important;
  }

  .suds-maintenance__actions a,
  .suds-maintenance__tiers a {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 1.45rem;
    font-weight: 950;
    text-decoration: none;
  }

  .suds-maintenance__actions a:first-child,
  .suds-maintenance__tiers .is-featured a {
    background: #ffdd00;
    color: #050505;
  }

  .suds-maintenance__tiers {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    padding: 22px 0 clamp(58px, 7vw, 96px);
  }

  .suds-maintenance__tiers article {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 28px;
    border: 1px solid #ded8c8;
    border-radius: 16px;
    background: #ffffff;
    box-shadow: 0 18px 45px rgba(0, 0, 0, .06);
  }

  .suds-maintenance__tiers .is-featured {
    border-color: rgba(255, 221, 0, .8);
    box-shadow: 0 28px 70px rgba(0, 0, 0, .12);
  }

  .suds-maintenance__tiers h2 {
    color: #050505;
    font-size: clamp(3.2rem, 4vw, 5rem);
  }

  .suds-maintenance__tiers p,
  .suds-maintenance__tiers li,
  .suds-maintenance__note p {
    color: #292929;
    font-size: 1.55rem;
    line-height: 1.5;
  }

  .suds-maintenance__tiers ul {
    display: grid;
    gap: 9px;
    margin: 20px 0 24px;
    padding: 0;
    list-style: none;
  }

  .suds-maintenance__tiers li {
    position: relative;
    padding-left: 24px;
  }

  .suds-maintenance__tiers li::before {
    content: "";
    position: absolute;
    top: .55em;
    left: 0;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #2bc653;
  }

  .suds-maintenance__tiers a {
    width: 100%;
    margin-top: auto;
  }

  .suds-maintenance__note {
    padding: 0 0 clamp(62px, 8vw, 110px);
  }

  .suds-maintenance__note h2 {
    font-size: clamp(3rem, 4.5vw, 5rem);
  }

  .suds-maintenance__note p {
    max-width: 780px;
    margin-top: 14px;
  }

  @media screen and (max-width: 850px) {
    .suds-maintenance__tiers {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Suds maintenance plan",
  "settings": []
}
{% endschema %}
