<section class="suds-home">
  <div class="suds-home__wrap">
    <p class="suds-home__eyebrow">Private mobile auto detailing in Seattle and surrounding areas</p>
    <h1>Premium mobile detailing that comes to your home.</h1>
    <p class="suds-home__lead">
      Suds Auto Salon is built for drivers who want the vehicle reset properly without dropping it off at a shop.
      Book interior details, full detail resets, maintenance plans, and paint protection handled by Sam at your driveway,
      office, apartment, or approved service location.
    </p>

    <div class="suds-home__actions">
      <a class="suds-home__button suds-home__button--primary" href="{{ routes.collections_url }}/mobile-details">Book a Mobile Detail</a>
      <a class="suds-home__button suds-home__button--secondary" href="/pages/contact">Send Photos for a Quote</a>
    </div>

    <div class="suds-home__proof" aria-label="Suds Auto Salon service highlights">
      <span>Seattle</span>
      <span>Bellevue</span>
      <span>Everett</span>
      <span>Edmonds</span>
      <span>Marysville</span>
      <span>Lake Stevens</span>
      <span>Snohomish</span>
    </div>

    <div class="suds-package-grid">
      <article class="suds-package">
        <p class="suds-package__label">Entry upkeep</p>
        <h2>Basic Detail</h2>
        <p>Best for vehicles that are already in decent condition and need a clean maintenance visit.</p>
        <a href="{{ routes.collections_url }}/mobile-details">View Basic Detail</a>
      </article>

      <article class="suds-package suds-package--featured">
        <p class="suds-package__label">Most booked</p>
        <h2>Signature Detail</h2>
        <p>The best first choice for most vehicles: interior reset, exterior wash, wheels, glass, trim, and protection options.</p>
        <a href="{{ routes.collections_url }}/mobile-details">Book Signature Detail</a>
      </article>

      <article class="suds-package">
        <p class="suds-package__label">Highest transformation</p>
        <h2>Elite Reset</h2>
        <p>For neglected interiors, resale prep, family SUVs, pet vehicles, and cars that need the full reset.</p>
        <a href="{{ routes.collections_url }}/mobile-details">View Elite Reset</a>
      </article>
    </div>
  </div>
</section>

<section class="suds-money">
  <div class="suds-money__wrap">
    <div>
      <p class="suds-home__eyebrow">Recommended upgrade</p>
      <h2>Get it reset once. Keep it clean every month.</h2>
      <p>
        After a Signature Detail or Elite Reset, ask about a maintenance plan. Monthly service keeps the vehicle from
        sliding back into stains, dust, pet hair, and road grime, while giving you priority scheduling with Suds Auto Salon.
      </p>
    </div>
    <a class="suds-home__button suds-home__button--primary" href="/pages/contact">Ask About Maintenance</a>
  </div>
</section>

<section class="suds-seo">
  <div class="suds-seo__wrap">
    <h2>Mobile detailing for Seattle, Bellevue, Everett, Edmonds, Lynnwood, Marysville, Lake Stevens, and Snohomish.</h2>
    <p>
      Suds Auto Salon provides mobile car detailing across the Seattle area, including interior car detailing, full
      auto detailing, ceramic coating, paint enhancement, pet hair removal, odor treatment, and maintenance detailing.
      If you searched for mobile detailing near me, car detailing Seattle, auto detailing Seattle, or ceramic coating
      Seattle, this is the private mobile detailer built for convenience and premium results.
    </p>
  </div>
</section>

<style>
  .suds-home,
  .suds-money,
  .suds-seo {
    background: #090909;
    color: #ffffff;
  }

  .suds-home__wrap,
  .suds-money__wrap,
  .suds-seo__wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 64px 20px;
  }

  .suds-home__eyebrow,
  .suds-package__label {
    margin: 0 0 12px;
    color: #f2d36b;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .suds-home h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(3.6rem, 7vw, 7.2rem);
    line-height: .95;
    letter-spacing: 0;
  }

  .suds-home h2,
  .suds-money h2,
  .suds-seo h2 {
    margin: 0 0 16px;
    font-size: clamp(2.6rem, 4vw, 4.6rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .suds-home__lead,
  .suds-money p,
  .suds-seo p,
  .suds-package p {
    color: #e8e8e8;
    font-size: 1.7rem;
    line-height: 1.55;
  }

  .suds-home__lead {
    max-width: 820px;
    margin: 20px 0 0;
  }

  .suds-home__actions,
  .suds-money__wrap {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .suds-home__actions {
    margin-top: 28px;
  }

  .suds-money__wrap {
    justify-content: space-between;
    background: #151515;
  }

  .suds-money__wrap > div {
    max-width: 760px;
  }

  .suds-home__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 13px 20px;
    border: 1px solid #f2d36b;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 800;
  }

  .suds-home__button--primary {
    background: #f2d36b;
    color: #090909;
  }

  .suds-home__button--secondary {
    background: transparent;
    color: #f2d36b;
  }

  .suds-home__proof {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .suds-home__proof span {
    border: 1px solid rgba(242, 211, 107, .35);
    border-radius: 999px;
    padding: 8px 12px;
    color: #f8e8a3;
    font-size: 1.3rem;
  }

  .suds-package-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 42px;
  }

  .suds-package {
    border: 1px solid rgba(255, 255, 255, .16);
    border-radius: 8px;
    padding: 24px;
    background: #121212;
  }

  .suds-package--featured {
    border-color: #f2d36b;
    background: #1b170d;
  }

  .suds-package a {
    color: #f2d36b;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .suds-seo {
    background: #ffffff;
    color: #111111;
  }

  .suds-seo p {
    color: #292929;
  }

  @media screen and (max-width: 749px) {
    .suds-home__wrap,
    .suds-money__wrap,
    .suds-seo__wrap {
      padding: 44px 18px;
    }

    .suds-package-grid {
      grid-template-columns: 1fr;
    }

    .suds-home__actions,
    .suds-money__wrap {
      align-items: stretch;
      flex-direction: column;
    }

    .suds-home__button {
      width: 100%;
    }
  }
</style>

