<section class="suds-home">
  <div class="suds-home__wrap">
    <div class="suds-home__hero">
      <div>
        <p class="suds-home__eyebrow">Seattle mobile detailing by appointment</p>
        <h1>Your car cleaned at home, without the shop drop-off.</h1>
        <p class="suds-home__lead">
          Suds Auto Salon is Sam's private mobile detailing service for busy drivers, families, pet owners,
          resale prep, and vehicle owners who want a cleaner cabin and a better-looking finish without losing half a day.
        </p>
        <div class="suds-home__actions">
          <a class="suds-home__button suds-home__button--primary" href="{{ routes.collections_url }}/mobile-details">Book a Mobile Detail</a>
          <a class="suds-home__button suds-home__button--secondary" href="/pages/contact-us">Send Photos for a Quote</a>
        </div>
      </div>

      <aside class="suds-home__panel" aria-label="Best first booking">
        <p class="suds-package__label">Best first booking</p>
        <h2>Signature Detail</h2>
        <p>
          The right choice for most vehicles that need both the interior and exterior brought back up without jumping
          straight into ceramic coating or paint correction.
        </p>
        <ul>
          <li>Interior reset for dust, crumbs, grime, light stains, and glass.</li>
          <li>Exterior wash, wheels, tires, trim, and finish cleanup.</li>
          <li>Protection, pet hair, odor, and stain upgrades available.</li>
        </ul>
      </aside>
    </div>

    <div class="suds-home__proof" aria-label="Suds Auto Salon service areas">
      <span>Seattle</span>
      <span>Bellevue</span>
      <span>Edmonds</span>
      <span>Lynnwood</span>
      <span>Everett</span>
      <span>Marysville</span>
      <span>Lake Stevens</span>
      <span>Snohomish</span>
    </div>

    <div class="suds-package-grid">
      <article class="suds-package">
        <p class="suds-package__label">Clean upkeep</p>
        <h2>Basic Detail</h2>
        <p>For vehicles already in decent shape. Good for upkeep, light mess, and maintenance clients.</p>
        <a href="{{ routes.collections_url }}/mobile-details">View Basic</a>
      </article>

      <article class="suds-package suds-package--featured">
        <p class="suds-package__label">Most booked</p>
        <h2>Signature Detail</h2>
        <p>For most first-time bookings. A stronger inside-and-out clean with upgrade room for protection or problem areas.</p>
        <a href="{{ routes.collections_url }}/mobile-details">Book Signature</a>
      </article>

      <article class="suds-package">
        <p class="suds-package__label">Heavy reset</p>
        <h2>Elite Reset</h2>
        <p>For neglected interiors, family SUVs, pet vehicles, resale prep, and cars that need more time.</p>
        <a href="{{ routes.collections_url }}/mobile-details">View Elite</a>
      </article>
    </div>
  </div>
</section>

<section class="suds-money">
  <div class="suds-money__wrap">
    <div>
      <p class="suds-home__eyebrow">Maintenance plan</p>
      <h2>Stop waiting until the car gets bad again.</h2>
      <p>
        After the first reset, monthly maintenance keeps the vehicle under control and gives you priority scheduling.
        Best for commuter cars, family vehicles, luxury cars, and anyone who wants a clean car without rethinking it every month.
      </p>
    </div>
    <a class="suds-home__button suds-home__button--primary" href="/pages/contact-us">Ask About Maintenance</a>
  </div>
</section>

<section class="suds-seo">
  <div class="suds-seo__wrap">
    <h2>Mobile detailing in Seattle, Bellevue, Edmonds, Everett, Marysville, Lake Stevens, and Snohomish.</h2>
    <p>
      Suds Auto Salon provides mobile car detailing, interior detailing, full detail resets, ceramic protection,
      paint enhancement, pet hair removal, odor treatment, and maintenance detailing across the Seattle area.
    </p>
  </div>
</section>

<style>
  .suds-home,
  .suds-money,
  .suds-seo {
    background: #ffffff;
    color: #111111;
  }

  .suds-home__wrap,
  .suds-money__wrap,
  .suds-seo__wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 64px 20px;
  }

  .suds-home__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, .85fr);
    gap: 34px;
    align-items: center;
  }

  .suds-home__eyebrow,
  .suds-package__label {
    margin: 0 0 12px;
    color: #8c6b05;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .suds-home h1 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(4rem, 7vw, 7.4rem);
    line-height: .94;
    letter-spacing: 0;
  }

  .suds-home h2,
  .suds-money h2,
  .suds-seo h2 {
    margin: 0 0 16px;
    font-size: clamp(2.6rem, 4vw, 4.8rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .suds-home__lead,
  .suds-money p,
  .suds-seo p,
  .suds-package p,
  .suds-home__panel p,
  .suds-home__panel li {
    color: #292929;
    font-size: 1.7rem;
    line-height: 1.55;
  }

  .suds-home__lead {
    max-width: 760px;
    margin: 20px 0 0;
  }

  .suds-home__actions,
  .suds-money__wrap {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .suds-home__actions {
    margin-top: 28px;
  }

  .suds-home__panel,
  .suds-package {
    border: 1px solid #e1e1e1;
    border-radius: 8px;
    padding: 24px;
    background: #ffffff;
    box-shadow: 0 14px 36px rgba(17, 17, 17, .06);
  }

  .suds-home__panel {
    border-color: #b9931b;
    background: #fffaf0;
  }

  .suds-home__panel ul {
    margin: 18px 0 0;
    padding-left: 20px;
  }

  .suds-money__wrap {
    justify-content: space-between;
    background: #f7f7f7;
    border-top: 1px solid #e6e0cc;
    border-bottom: 1px solid #e6e0cc;
  }

  .suds-money__wrap > div {
    max-width: 760px;
  }

  .suds-home__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 13px 20px;
    border: 1px solid #111111;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 800;
  }

  .suds-home__button--primary {
    background: #111111;
    color: #ffffff;
  }

  .suds-home__button--secondary {
    background: transparent;
    color: #111111;
  }

  .suds-home__proof {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .suds-home__proof span {
    border: 1px solid #d8c47a;
    border-radius: 999px;
    padding: 8px 12px;
    color: #5d4704;
    font-size: 1.3rem;
    background: #fffdf7;
  }

  .suds-package-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 42px;
  }

  .suds-package--featured {
    border-color: #b9931b;
    background: #fffaf0;
  }

  .suds-package a {
    color: #6d5206;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .suds-seo p {
    color: #292929;
  }

  @media screen and (max-width: 900px) {
    .suds-home__hero,
    .suds-package-grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .suds-home__wrap,
    .suds-money__wrap,
    .suds-seo__wrap {
      padding: 44px 18px;
    }

    .suds-home__actions,
    .suds-money__wrap {
      align-items: stretch;
      flex-direction: column;
    }

    .suds-home__button {
      width: 100%;
    }
  }
</style>

