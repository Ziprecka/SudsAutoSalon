{%- liquid
  assign hide_for_suds_service_product = false
  if request.page_type == 'product'
    case product.handle
      when 'basic-detail', 'mini-detail', 'signature-detail', 'interior-detail', 'elite-detail', 'full-detail'
        assign hide_for_suds_service_product = true
    endcase

    assign suds_detail_title = product.title | downcase
    if hide_for_suds_service_product == false
      if suds_detail_title contains 'basic detail'
        assign hide_for_suds_service_product = true
      elsif suds_detail_title contains 'mini detail'
        assign hide_for_suds_service_product = true
      elsif suds_detail_title contains 'signature detail'
        assign hide_for_suds_service_product = true
      elsif suds_detail_title contains 'interior detail'
        assign hide_for_suds_service_product = true
      elsif suds_detail_title contains 'elite detail'
        assign hide_for_suds_service_product = true
      elsif suds_detail_title contains 'full detail'
        assign hide_for_suds_service_product = true
      endif
    endif
  endif
-%}

{%- unless hide_for_suds_service_product -%}
<section class="suds-product-guide">
  <div class="suds-product-guide__wrap">
    <p class="suds-product-guide__eyebrow">Before you book</p>
    <h2>Not sure this is the right package?</h2>
    <p>Request a quote with your vehicle, city, and photos. Sam will confirm whether Basic, Signature, Elite Reset, ceramic protection, or maintenance is the smarter fit before you pay.</p>
    <div class="suds-product-guide__actions">
      <a href="/pages/contact-us">Request a Quote</a>
      <a href="sms:+14253618838">Text Photos for a Faster Quote</a>
    </div>
  </div>
</section>

<style>
  .suds-product-guide { background: #f8f7f2; color: #111; }
  .suds-product-guide__wrap { max-width: 1180px; margin: 0 auto; padding: 34px 20px; }
  .suds-product-guide__eyebrow { margin: 0 0 8px; color: #8c6b05; font-weight: 800; text-transform: uppercase; }
  .suds-product-guide h2 { margin: 0; letter-spacing: 0; }
  .suds-product-guide p { max-width: 820px; color: #292929; font-size: 1.55rem; line-height: 1.5; }
  .suds-product-guide__actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 16px; }
  .suds-product-guide__actions a { display: inline-flex; min-height: 44px; align-items: center; justify-content: center; padding: 11px 16px; border-radius: 4px; background: #111; color: #fff; font-weight: 800; text-decoration: none; }
</style>
{%- endunless -%}

{% schema %}
{ "name": "Suds product booking guide", "settings": [], "presets": [{ "name": "Suds product booking guide" }] }
{% endschema %}
